#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${ROOT_DIR}"

if [[ ! -f "${ROOT_DIR}/build/index.js" ]]; then
  echo "No Node adapter build found at build/index.js."
  echo "Run ./scripts/build before ./scripts/serve."
  exit 1
fi

export HOST="${HOST:-0.0.0.0}"
export PORT="${PORT:-4173}"
export ORIGIN="${ORIGIN:-http://${HOST}:${PORT}}"

echo "Serving built UI on http://${HOST}:${PORT} (origin=${ORIGIN})"
echo "Canonical config: set OAR_WORKSPACES (and optionally OAR_DEFAULT_WORKSPACE)."
echo "Compatibility aliases: OAR_PROJECTS and OAR_DEFAULT_PROJECT are still accepted."
echo "Single-core dev fallback: set OAR_CORE_BASE_URL to synthesize the default 'local' workspace."

exec node build/index.js
