#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

CORE_BASE_URL="${OAR_CORE_BASE_URL:-http://127.0.0.1:8000}"
WORKSPACE_SLUG="${OAR_E2E_WORKSPACE:-${OAR_E2E_PROJECT:-${OAR_DEFAULT_WORKSPACE:-${OAR_DEFAULT_PROJECT:-local}}}}"
HEALTHCHECK_TIMEOUT_SECONDS="${OAR_CORE_HEALTHCHECK_TIMEOUT_SECONDS:-5}"

WORKSPACE_CATALOG="${OAR_WORKSPACES:-${OAR_PROJECTS:-}}"

if [[ -n "${WORKSPACE_CATALOG:-}" ]]; then
  if ! CORE_BASE_URL="$(
    WORKSPACE_SLUG="${WORKSPACE_SLUG}" WORKSPACE_CATALOG="${WORKSPACE_CATALOG}" python3 - <<'PY'
import json
import os
import sys

workspace_slug = os.environ["WORKSPACE_SLUG"]
raw = os.environ["WORKSPACE_CATALOG"]
parsed = json.loads(raw)

if isinstance(parsed, dict):
    items = []
    for slug, value in parsed.items():
        entry = dict(value or {})
        entry.setdefault("slug", slug)
        items.append(entry)
else:
    items = parsed

for item in items:
    if str(item.get("slug", "")).strip() != workspace_slug:
        continue
    base_url = str(
        item.get("coreBaseUrl") or item.get("core_base_url") or ""
    ).strip().rstrip("/")
    if not base_url:
        sys.exit(2)
    print(base_url)
    sys.exit(0)

sys.exit(1)
PY
  )"; then
    cat >&2 <<EOF
ERROR: Could not resolve workspace '${WORKSPACE_SLUG}' from OAR_WORKSPACES/OAR_PROJECTS.
Set OAR_WORKSPACES to include that slug, or omit the workspace catalog and set OAR_CORE_BASE_URL.
EOF
    exit 1
  fi
else
  CORE_BASE_URL="${CORE_BASE_URL%/}"
  export OAR_WORKSPACES="[{\"slug\":\"${WORKSPACE_SLUG}\",\"label\":\"${WORKSPACE_SLUG}\",\"coreBaseUrl\":\"${CORE_BASE_URL}\"}]"
fi

CORE_BASE_URL="${CORE_BASE_URL%/}"
VERSION_URL="${CORE_BASE_URL}/version"
HANDSHAKE_URL="${CORE_BASE_URL}/meta/handshake"
export OAR_DEFAULT_WORKSPACE="${WORKSPACE_SLUG}"
export OAR_DEFAULT_PROJECT="${WORKSPACE_SLUG}"
if [[ -n "${OAR_WORKSPACES:-}" ]]; then
  export OAR_PROJECTS="${OAR_PROJECTS:-${OAR_WORKSPACES}}"
fi

echo "Checking oar-core availability at ${HANDSHAKE_URL} ..."
if ! version_payload="$(
  curl \
    --silent \
    --show-error \
    --fail \
    --max-time "${HEALTHCHECK_TIMEOUT_SECONDS}" \
    "${HANDSHAKE_URL}"
)"; then
  echo "Handshake check failed, falling back to ${VERSION_URL} ..."
  if ! version_payload="$(
    curl \
      --silent \
      --show-error \
      --fail \
      --max-time "${HEALTHCHECK_TIMEOUT_SECONDS}" \
      "${VERSION_URL}"
  )"; then
  cat >&2 <<EOF
ERROR: Unable to reach oar-core at ${CORE_BASE_URL}.
Start backend first, then rerun this command.

Backend terminal:
  cd ../core
  ./scripts/dev

UI terminal:
  cd ../web-ui
  OAR_WORKSPACES='[{"slug":"local","label":"Local","coreBaseUrl":"http://127.0.0.1:8000"}]' \
  OAR_DEFAULT_WORKSPACE=local \
  ./scripts/e2e-with-core
EOF
  exit 1
  fi
fi

if [[ "${version_payload}" != *'"schema_version"'* ]]; then
  cat >&2 <<EOF
ERROR: core compatibility endpoint responded but did not return a schema_version payload.
Response body:
${version_payload}
EOF
  exit 1
fi

echo "oar-core /version response: ${version_payload}"

cd "${REPO_ROOT}"
pnpm install --frozen-lockfile
pnpm exec playwright install chromium

export OAR_CORE_BASE_URL="${CORE_BASE_URL}"

exec pnpm exec playwright test --config playwright.integration.config.js "$@"
