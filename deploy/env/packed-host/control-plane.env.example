# Shared control plane, loopback only.
OAR_CONTROL_PLANE_LISTEN_ADDR=127.0.0.1:8100
OAR_CONTROL_PLANE_WORKSPACE_ROOT=/var/lib/oar/control-plane

# Public origin used for passkeys and workspace launch URLs.
OAR_CONTROL_PLANE_WEBAUTHN_RPID=app.example.com
OAR_CONTROL_PLANE_WEBAUTHN_ORIGIN=https://app.example.com
OAR_CONTROL_PLANE_WORKSPACE_URL_TEMPLATE=https://app.example.com/%s
OAR_CONTROL_PLANE_INVITE_URL_TEMPLATE=https://app.example.com/invites/%s

# Signed workspace grants for control-plane-managed human auth.
OAR_CONTROL_PLANE_WORKSPACE_GRANT_ISSUER=https://app.example.com
OAR_CONTROL_PLANE_WORKSPACE_GRANT_AUDIENCE=oar-core
OAR_CONTROL_PLANE_WORKSPACE_GRANT_SIGNING_KEY=REPLACE_WITH_BASE64_ED25519_PRIVATE_KEY

OAR_CONTROL_PLANE_SESSION_TTL=12h
OAR_CONTROL_PLANE_CEREMONY_TTL=5m
OAR_CONTROL_PLANE_LAUNCH_TTL=10m
OAR_CONTROL_PLANE_INVITE_TTL=168h
OAR_CONTROL_PLANE_BACKUP_MAINTENANCE_INTERVAL=5m
OAR_CONTROL_PLANE_SHUTDOWN_TIMEOUT=15s

# Target-state packed-host placement config after the placement ticket lands.
OAR_CONTROL_PLANE_LOCAL_HOST_ID=host-01
OAR_CONTROL_PLANE_LOCAL_HOST_LABEL=primary
OAR_CONTROL_PLANE_LOCAL_HOST_ROOT=/var/lib/oar/workspaces
OAR_CONTROL_PLANE_LOCAL_HOST_PORT_START=18000
OAR_CONTROL_PLANE_LOCAL_HOST_PORT_END=19999
OAR_CONTROL_PLANE_HOSTED_SCRIPTS_DIR=/opt/oar/scripts/hosted
OAR_CONTROL_PLANE_VERIFY_CORE_BINARY=/opt/oar/bin/oar-core
OAR_CONTROL_PLANE_VERIFY_SCHEMA_PATH=/opt/oar/share/oar-schema.yaml
