# Loopback listener for one workspace core.
OAR_LISTEN_ADDR=127.0.0.1:18001

# Packed-host instance roots keep workspace/, config/, metadata/, and backups/
# together. The runtime workspace root points at the workspace/ subdirectory.
OAR_WORKSPACE_ROOT=/var/lib/oar/workspaces/ws_example/workspace

# Installed shared assets.
OAR_SCHEMA_PATH=/opt/oar/share/oar-schema.yaml
OAR_META_COMMANDS_PATH=/opt/oar/share/meta/commands.json
OAR_CORE_INSTANCE_ID=ws_example

# Auth mode for SaaS.
OAR_HUMAN_AUTH_MODE=control_plane
OAR_CONTROL_PLANE_BASE_URL=http://127.0.0.1:8100
OAR_CONTROL_PLANE_HEARTBEAT_INTERVAL=30s
OAR_CONTROL_PLANE_TOKEN_ISSUER=https://app.example.com
OAR_CONTROL_PLANE_TOKEN_AUDIENCE=oar-core
OAR_CONTROL_PLANE_WORKSPACE_ID=ws_example
OAR_CONTROL_PLANE_TOKEN_PUBLIC_KEY=REPLACE_WITH_BASE64_ED25519_PUBLIC_KEY
OAR_WORKSPACE_SERVICE_ID=svc_ws_example
OAR_WORKSPACE_SERVICE_PRIVATE_KEY=REPLACE_WITH_BASE64_ED25519_PRIVATE_KEY

# Production defaults.
OAR_ALLOW_UNAUTHENTICATED_WRITES=false
OAR_ENABLE_DEV_ACTOR_MODE=false
OAR_SHUTDOWN_TIMEOUT=15s

# Projection maintenance. Set OAR_PROJECTION_MODE=manual to disable the
# background loop and rely on explicit rebuilds.
OAR_PROJECTION_MODE=background
OAR_PROJECTION_MAINTENANCE_INTERVAL=5s
OAR_PROJECTION_STALE_SCAN_INTERVAL=30s
OAR_PROJECTION_MAINTENANCE_BATCH_SIZE=50

# Blob backend. Start with filesystem unless you explicitly want S3-compatible blobs.
OAR_BLOB_BACKEND=filesystem
# OAR_BLOB_BACKEND=s3
# OAR_BLOB_S3_BUCKET=oar-workspace-blobs
# OAR_BLOB_S3_PREFIX=workspaces/ws_example/
# OAR_BLOB_S3_REGION=auto
# OAR_BLOB_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# OAR_BLOB_S3_ACCESS_KEY_ID=REPLACE_ME
# OAR_BLOB_S3_SECRET_ACCESS_KEY=REPLACE_ME
# OAR_BLOB_S3_SESSION_TOKEN=REPLACE_ME_IF_USING_TEMPORARY_CREDS
# OAR_BLOB_S3_FORCE_PATH_STYLE=true
