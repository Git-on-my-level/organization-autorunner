[Unit]
Description=OAR shared web UI
After=network-online.target oar-control-plane.service
Wants=network-online.target

[Service]
Type=simple
User=oar
Group=oar
EnvironmentFile=/etc/oar/web-ui.env
WorkingDirectory=/opt/oar/web-ui
ExecStart=/usr/bin/env node /opt/oar/web-ui/build/index.js
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/oar/web-ui

[Install]
WantedBy=multi-user.target
