{
  "name": "organization-autorunner-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . && node scripts/check-svelte5-runes.js && prettier --check \"src/**/*.{js,svelte,css}\" \"tests/**/*.js\" \"*.{json,js,cjs}\" \".github/workflows/*.yml\"",
    "format": "prettier --write \"src/**/*.{js,svelte,css}\" \"tests/**/*.js\" \"*.{json,js,cjs}\" \".github/workflows/*.yml\"",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "pnpm run lint && pnpm run test:unit && pnpm run test:e2e"
  },
  "dependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/kit": "^2.5.18",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.51.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.14",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
