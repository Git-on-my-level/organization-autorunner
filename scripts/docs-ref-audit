#!/usr/bin/env python3
"""docs-ref-audit: Audit agent-facing docs for broken local path references.
Exit code 0 = all references valid, non-zero = broken references found.
"""

import re
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).parent.parent.resolve()

AGENT_DOCS = [
    REPO_ROOT / "AGENTS.md",
    REPO_ROOT / "core" / "AGENTS.md",
    REPO_ROOT / "cli" / "AGENTS.md",
    REPO_ROOT / "web-ui" / "AGENTS.md",
]

README_FILES = [
    REPO_ROOT / "README.md",
    REPO_ROOT / "core" / "README.md",
    REPO_ROOT / "cli" / "README.md",
    REPO_ROOT / "web-ui" / "README.md",
]

EXTERNAL_MARKERS = ["http://", "https://", "mailto:", "github.com", "docker.com"]

KNOWN_ABSENT = [".codex-autorunner/contextspace/", ".codex-autorunner/tickets/"]


def check_file(file_path: Path, files_to_check: list[Path]) -> int:
    if not file_path.is_file():
        print(f"ERROR: Agent doc file not found: {file_path}")
        return 1

    errors = 0
    content = file_path.read_text()

    link_pattern = re.compile(r'\[([^\]]+)\]\(([^)]+)\)')
    
    for lineno, line in enumerate(content.splitlines(), 1):
        is_external = False
        for marker in EXTERNAL_MARKERS:
            if marker in line:
                is_external = True
                break
        
        if is_external:
            continue

        for match in link_pattern.finditer(line):
            ref = match.group(2)

            is_known = False
            for k in KNOWN_ABSENT:
                if k in ref:
                    is_known = True
                    break
            
            if is_known:
                continue

            if ref.startswith('/'):
                full_path = REPO_ROOT / ref.lstrip('/')
            elif ref.startswith('#'):
                continue
            elif ref.startswith('tel:') or ref.startswith('javascript:'):
                continue
            else:
                full_path = file_path.parent / ref

            if full_path.is_file():
                continue

            print(f"{file_path}:{lineno}: broken reference: {ref}")
            errors += 1

    return errors


def main():
    all_files = [f for f in AGENT_DOCS + README_FILES if f.is_file()]
    
    print("Auditing agent-facing docs for broken local path references...")
    print()

    total_errors = 0
    for file_path in all_files:
        errors = check_file(file_path, all_files)
        if errors > 0:
            total_errors += 1

    print()

    if total_errors > 0:
        print(f"FAILED: {total_errors} file(s) with broken references found")
        sys.exit(1)

    print("PASSED: All local path references are valid")
    sys.exit(0)


if __name__ == "__main__":
    main()
