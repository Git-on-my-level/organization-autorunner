#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/hosted/common.sh"

ARTIFACT_DIR="${SAAS_E2E_ARTIFACT_DIR:-$REPO_ROOT/.tmp/saas-e2e}"
CONTROL_PLANE_PORT="${CONTROL_PLANE_PORT:-18110}"
CONTROL_PLANE_HOST="127.0.0.1"
CONTROL_PLANE_BASE_URL="http://${CONTROL_PLANE_HOST}:${CONTROL_PLANE_PORT}"
E2E_TIMEOUT_SECONDS="${SAAS_E2E_TIMEOUT_SECONDS:-180}"

mkdir -p "$ARTIFACT_DIR"
TMP_DIR="$(mktemp -d "$ARTIFACT_DIR/run.XXXXXX")"
CONTROL_PLANE_LOG="$TMP_DIR/control-plane.log"
WORKSPACE1_LOG="$TMP_DIR/workspace1.log"
WORKSPACE2_LOG="$TMP_DIR/workspace2.log"
CONTROL_PLANE_ROOT="$TMP_DIR/control-plane-root"

cleanup() {
  local code=$?
  stop_background_process "${WORKSPACE2_PID:-}"
  stop_background_process "${WORKSPACE1_PID:-}"
  stop_background_process "${CONTROL_PLANE_PID:-}"

  if [[ $code -ne 0 ]]; then
    echo "saas e2e failed; artifacts kept at: $TMP_DIR" >&2
    echo "control-plane log: $CONTROL_PLANE_LOG" >&2
    echo "workspace1 log: $WORKSPACE1_LOG" >&2
    echo "workspace2 log: $WORKSPACE2_LOG" >&2
  else
    echo "saas e2e artifacts: $TMP_DIR"
  fi
}
trap cleanup EXIT INT TERM

require_command curl go python3

assert_http_status() {
  local expected_status="$1"
  local actual_status="$2"
  local context="$3"
  if [[ "$expected_status" != "$actual_status" ]]; then
    echo "assertion failed: expected HTTP $expected_status, got $actual_status ($context)" >&2
    exit 1
  fi
}

json_get() {
  local json="$1"
  local path="$2"
  python3 "${REPO_ROOT}/scripts/hosted/json-tool.py" get "$path" <<<"$json"
}

json_get_first() {
  local json="$1"
  shift
  local path value
  for path in "$@"; do
    if value="$(json_get "$json" "$path" 2>/dev/null)"; then
      printf '%s\n' "$value"
      return 0
    fi
  done
  return 1
}

invite_token_from_url() {
  local invite_url="$1"
  python3 -c '
import sys
from urllib.parse import urlparse

path = urlparse(sys.argv[1]).path.rstrip("/")
prefix = "/invites/"
if not path.startswith(prefix):
    raise SystemExit(1)
print(path[len(prefix):])
' "$invite_url"
}

generate_ed25519_key_base64() {
  local go_file
  go_file="$(mktemp "${TMP_DIR}/genkey.XXXXXX.go")"
  cat >"$go_file" <<'EOF'
package main
import (
	"crypto/ed25519"
	"crypto/rand"
	"encoding/base64"
	"fmt"
	"os"
)
func main() {
	publicKey, privateKey, err := ed25519.GenerateKey(rand.Reader)
	if err != nil {
		fmt.Fprintf(os.Stderr, "failed to generate key: %v\n", err)
		os.Exit(1)
	}
	fmt.Println(base64.StdEncoding.EncodeToString(publicKey))
	fmt.Println(base64.StdEncoding.EncodeToString(privateKey))
}
EOF
  go run "$go_file"
  rm -f "$go_file"
}

echo "Building core binary..."
CORE_BIN="$(build_core_binary "$TMP_DIR/oar-core")"
SCHEMA_PATH="$(resolve_schema_path)"

echo "Generating workspace service identity key pair..."
KEYS=$(generate_ed25519_key_base64)
SERVICE_PUBLIC_KEY=$(echo "$KEYS" | sed -n '1p')
SERVICE_PRIVATE_KEY=$(echo "$KEYS" | sed -n '2p')

echo "Starting control plane..."
mkdir -p "$CONTROL_PLANE_ROOT"
(
  export OAR_CONTROL_PLANE_WEBAUTHN_RPID="localhost"
  export OAR_CONTROL_PLANE_WEBAUTHN_ORIGIN="http://localhost:5173"
  export OAR_CONTROL_PLANE_WORKSPACE_GRANT_ISSUER="$CONTROL_PLANE_BASE_URL"
  export OAR_CONTROL_PLANE_WORKSPACE_GRANT_AUDIENCE="oar-core"
  export OAR_CONTROL_PLANE_WORKSPACE_GRANT_SIGNING_KEY="$SERVICE_PRIVATE_KEY"
  export OAR_CONTROL_PLANE_WORKSPACE_URL_TEMPLATE="http://127.0.0.1/%s"
  export OAR_CONTROL_PLANE_INVITE_URL_TEMPLATE="${CONTROL_PLANE_BASE_URL}/invites/%s"
  cd "$REPO_ROOT/core"
  go run ./cmd/oar-control-plane \
    --listen-addr "${CONTROL_PLANE_HOST}:${CONTROL_PLANE_PORT}" \
    --workspace-root "$CONTROL_PLANE_ROOT" \
    >"$CONTROL_PLANE_LOG" 2>&1
) &
CONTROL_PLANE_PID=$!

if ! wait_for_http_ok "$CONTROL_PLANE_BASE_URL/readyz" "$E2E_TIMEOUT_SECONDS"; then
  echo "control plane did not become healthy" >&2
  cat "$CONTROL_PLANE_LOG" >&2 || true
  exit 1
fi

echo "✓ Control plane started"

echo ""
echo "=== E2E Scenario: Account -> Organization -> Workspaces -> Launch -> Workspace Operations ==="

register_account() {
  local email="$1"
  local display_name="$2"
  local cred_suffix="$3"
  local invite_token="${4:-}"

  START_REG_RESPONSE=$(curl -sS \
    -H "content-type: application/json" \
    -H "origin: http://localhost:5173" \
    -X POST \
    -d "{\"email\":\"$email\",\"display_name\":\"$display_name\"}" \
    "$CONTROL_PLANE_BASE_URL/account/passkeys/registrations/start")

  REG_SESSION_ID="$(json_get_first "$START_REG_RESPONSE" registration_session_id id || true)"
  REG_OPTIONS="$(json_get "$START_REG_RESPONSE" public_key_options || true)"
  CHALLENGE="$(json_get "$REG_OPTIONS" challenge || true)"
  REG_USER_ID="$(json_get_first "$REG_OPTIONS" user.id id || true)"

  CREDENTIAL_ID="cred-${cred_suffix}-$(generate_token 8)"
  CLIENT_DATA=$(python3 -c "
import json, base64
data = {'challenge': '$CHALLENGE', 'origin': 'http://localhost:5173', 'type': 'webauthn.create'}
print(base64.urlsafe_b64encode(json.dumps(data).encode()).decode().rstrip('='))
")

  FINISH_REG_RESPONSE=$(curl -sS \
    -H "content-type: application/json" \
    -H "origin: http://localhost:5173" \
    -X POST \
    -d "{\"registration_session_id\":\"$REG_SESSION_ID\"${invite_token:+,\"invite_token\":\"$invite_token\"},\"credential\":{\"id\":\"$CREDENTIAL_ID\",\"rawId\":\"$CREDENTIAL_ID\",\"type\":\"public-key\",\"response\":{\"clientDataJSON\":\"$CLIENT_DATA\",\"userHandle\":\"$REG_USER_ID\"}}}" \
    "$CONTROL_PLANE_BASE_URL/account/passkeys/registrations/finish")

  printf '%s\n%s\n' \
    "$(json_get_first "$FINISH_REG_RESPONSE" session.access_token access_token || true)" \
    "$CREDENTIAL_ID"
}

login_account() {
  local email="$1"
  local credential_id="$2"

  START_LOGIN_RESPONSE=$(curl -sS \
    -H "content-type: application/json" \
    -H "origin: http://localhost:5173" \
    -X POST \
    -d "{\"email\":\"$email\"}" \
    "$CONTROL_PLANE_BASE_URL/account/sessions/start")

  LOGIN_SESSION_ID="$(json_get_first "$START_LOGIN_RESPONSE" session_id id || true)"
  LOGIN_OPTIONS="$(json_get "$START_LOGIN_RESPONSE" public_key_options || true)"
  CHALLENGE="$(json_get "$LOGIN_OPTIONS" challenge || true)"

  CLIENT_DATA=$(python3 -c "
import json, base64
data = {'challenge': '$CHALLENGE', 'origin': 'http://localhost:5173', 'type': 'webauthn.get'}
print(base64.urlsafe_b64encode(json.dumps(data).encode()).decode().rstrip('='))
")

  FINISH_LOGIN_RESPONSE=$(curl -sS \
    -H "content-type: application/json" \
    -H "origin: http://localhost:5173" \
    -X POST \
  -d "{\"session_id\":\"$LOGIN_SESSION_ID\",\"credential\":{\"id\":\"$credential_id\",\"rawId\":\"$credential_id\",\"type\":\"public-key\",\"response\":{\"clientDataJSON\":\"$CLIENT_DATA\"}}}" \
    "$CONTROL_PLANE_BASE_URL/account/sessions/finish")

  json_get_first "$FINISH_LOGIN_RESPONSE" session.access_token access_token || true
}

echo "Registering admin account..."
ADMIN_ACCOUNT_OUTPUT="$(register_account "admin@example.com" "Admin User" "admin")"
ADMIN_TOKEN="$(sed -n '1p' <<<"$ADMIN_ACCOUNT_OUTPUT")"
ADMIN_CREDENTIAL_ID="$(sed -n '2p' <<<"$ADMIN_ACCOUNT_OUTPUT")"
if [[ -z "$ADMIN_TOKEN" ]]; then
  echo "failed to register admin account" >&2
  exit 1
fi
echo "✓ Admin registered"

echo ""
echo "Creating organization..."
CREATE_ORG_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $ADMIN_TOKEN" \
  -X POST \
  -d '{"slug":"e2e-org","display_name":"E2E Organization","plan_tier":"team"}' \
  "$CONTROL_PLANE_BASE_URL/organizations")

ORG_ID="$(json_get_first "$CREATE_ORG_RESPONSE" organization.id id || true)"
echo "✓ Organization created (id=$ORG_ID)"

echo ""
echo "Provisioning workspace 1..."
WORKSPACE1_SERVICE_IDENTITY_ID="saas-e2e-ws1-service"
CREATE_WS1_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $ADMIN_TOKEN" \
  -X POST \
  -d "{\"organization_id\":\"$ORG_ID\",\"slug\":\"ws-alpha\",\"display_name\":\"Alpha Workspace\",\"region\":\"us-central1\",\"workspace_tier\":\"standard\",\"service_identity_id\":\"$WORKSPACE1_SERVICE_IDENTITY_ID\",\"service_identity_public_key\":\"$SERVICE_PUBLIC_KEY\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces")

WS1_ID="$(json_get_first "$CREATE_WS1_RESPONSE" workspace.id id || true)"
WS1_DEPLOYMENT_ROOT="$(json_get_first "$CREATE_WS1_RESPONSE" workspace.deployment_root deployment_root || true)"
echo "✓ Workspace 1 provisioned (id=$WS1_ID)"

echo ""
echo "Provisioning workspace 2..."
WORKSPACE2_SERVICE_IDENTITY_ID="saas-e2e-ws2-service"
CREATE_WS2_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $ADMIN_TOKEN" \
  -X POST \
  -d "{\"organization_id\":\"$ORG_ID\",\"slug\":\"ws-beta\",\"display_name\":\"Beta Workspace\",\"region\":\"us-east1\",\"workspace_tier\":\"plus\",\"service_identity_id\":\"$WORKSPACE2_SERVICE_IDENTITY_ID\",\"service_identity_public_key\":\"$SERVICE_PUBLIC_KEY\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces")

WS2_ID="$(json_get_first "$CREATE_WS2_RESPONSE" workspace.id id || true)"
WS2_DEPLOYMENT_ROOT="$(json_get_first "$CREATE_WS2_RESPONSE" workspace.deployment_root deployment_root || true)"
echo "✓ Workspace 2 provisioned (id=$WS2_ID)"

WORKSPACE1_PORT="18111"
WORKSPACE2_PORT="18112"

echo ""
echo "Starting workspace core 1..."
BOOTSTRAP_TOKEN1="e2e-ws1-$(generate_token 16)"
export OAR_HUMAN_AUTH_MODE="control_plane"
export OAR_CONTROL_PLANE_TOKEN_ISSUER="$CONTROL_PLANE_BASE_URL"
export OAR_CONTROL_PLANE_TOKEN_AUDIENCE="oar-core"
export OAR_CONTROL_PLANE_TOKEN_PUBLIC_KEY="$SERVICE_PUBLIC_KEY"
export OAR_CONTROL_PLANE_WORKSPACE_ID="$WS1_ID"
export OAR_WORKSPACE_SERVICE_ID="$WORKSPACE1_SERVICE_IDENTITY_ID"
export OAR_WORKSPACE_SERVICE_PRIVATE_KEY="$SERVICE_PRIVATE_KEY"
start_core_server \
  WORKSPACE1_PID \
  "$CORE_BIN" \
  "$WS1_DEPLOYMENT_ROOT/workspace" \
  "$SCHEMA_PATH" \
  "$CONTROL_PLANE_HOST" \
  "$WORKSPACE1_PORT" \
  "$WORKSPACE1_LOG" \
  "ws1-e2e-instance" \
  set \
  "$BOOTSTRAP_TOKEN1" \
  false \
  false \
  false

if ! wait_for_http_ok "http://${CONTROL_PLANE_HOST}:${WORKSPACE1_PORT}/readyz" 30; then
  echo "workspace 1 did not become healthy" >&2
  cat "$WORKSPACE1_LOG" >&2 || true
  exit 1
fi
WS1_BASE_URL="http://${CONTROL_PLANE_HOST}:${WORKSPACE1_PORT}"
echo "✓ Workspace 1 core running"

echo ""
echo "Starting workspace core 2..."
BOOTSTRAP_TOKEN2="e2e-ws2-$(generate_token 16)"
export OAR_CONTROL_PLANE_WORKSPACE_ID="$WS2_ID"
export OAR_WORKSPACE_SERVICE_ID="$WORKSPACE2_SERVICE_IDENTITY_ID"
export OAR_WORKSPACE_SERVICE_PRIVATE_KEY="$SERVICE_PRIVATE_KEY"
start_core_server \
  WORKSPACE2_PID \
  "$CORE_BIN" \
  "$WS2_DEPLOYMENT_ROOT/workspace" \
  "$SCHEMA_PATH" \
  "$CONTROL_PLANE_HOST" \
  "$WORKSPACE2_PORT" \
  "$WORKSPACE2_LOG" \
  "ws2-e2e-instance" \
  set \
  "$BOOTSTRAP_TOKEN2" \
  false \
  false \
  false

if ! wait_for_http_ok "http://${CONTROL_PLANE_HOST}:${WORKSPACE2_PORT}/readyz" 30; then
  echo "workspace 2 did not become healthy" >&2
  cat "$WORKSPACE2_LOG" >&2 || true
  exit 1
fi
WS2_BASE_URL="http://${CONTROL_PLANE_HOST}:${WORKSPACE2_PORT}"
unset OAR_HUMAN_AUTH_MODE
unset OAR_CONTROL_PLANE_TOKEN_ISSUER
unset OAR_CONTROL_PLANE_TOKEN_AUDIENCE
unset OAR_CONTROL_PLANE_TOKEN_PUBLIC_KEY
unset OAR_CONTROL_PLANE_WORKSPACE_ID
unset OAR_WORKSPACE_SERVICE_ID
unset OAR_WORKSPACE_SERVICE_PRIVATE_KEY
echo "✓ Workspace 2 core running"

echo ""
echo "=== Extended flow: Invite and member operations ==="

echo "Creating member invite..."
CREATE_INVITE_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $ADMIN_TOKEN" \
  -X POST \
  -d '{"email":"member@example.com","role":"member"}' \
  "$CONTROL_PLANE_BASE_URL/organizations/$ORG_ID/invites")
MEMBER_INVITE_URL="$(json_get_first "$CREATE_INVITE_RESPONSE" invite_url url || true)"
MEMBER_INVITE_TOKEN="$(invite_token_from_url "$MEMBER_INVITE_URL" || true)"
if [[ -z "$MEMBER_INVITE_TOKEN" ]]; then
  echo "failed to extract member invite token" >&2
  echo "response: $CREATE_INVITE_RESPONSE" >&2
  exit 1
fi
echo "✓ Member invited"

echo ""
echo "Registering member account..."
MEMBER_ACCOUNT_OUTPUT="$(register_account "member@example.com" "Member User" "member" "$MEMBER_INVITE_TOKEN")"
MEMBER_TOKEN="$(sed -n '1p' <<<"$MEMBER_ACCOUNT_OUTPUT")"
MEMBER_CREDENTIAL_ID="$(sed -n '2p' <<<"$MEMBER_ACCOUNT_OUTPUT")"
if [[ -z "$MEMBER_TOKEN" ]]; then
  echo "failed to register member account" >&2
  exit 1
fi
echo "✓ Member registered"

echo ""
echo "Verifying member can access organization..."
MEMBER_ORGS_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $MEMBER_TOKEN" \
  "$CONTROL_PLANE_BASE_URL/organizations")
MEMBER_ORG_COUNT=$(python3 "${REPO_ROOT}/scripts/hosted/json-tool.py" count-key-value id "$ORG_ID" <<<"$MEMBER_ORGS_RESPONSE" 2>/dev/null || echo "0")
if [[ "$MEMBER_ORG_COUNT" -lt 1 ]]; then
  echo "member should see organization" >&2
  exit 1
fi
echo "✓ Member sees organization"

echo ""
echo "=== Extended flow: Launch and cross-workspace isolation ==="

echo "Member launching workspace 1..."
LAUNCH1_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $MEMBER_TOKEN" \
  -X POST \
  -d '{"return_path":"/ws-alpha"}' \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS1_ID/launch-sessions")

EXCHANGE_TOKEN1="$(json_get_first "$LAUNCH1_RESPONSE" launch_session.exchange_token exchange_token || true)"
EXCHANGE1_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -X POST \
  -d "{\"exchange_token\":\"$EXCHANGE_TOKEN1\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS1_ID/session-exchange")

GRANT1_TOKEN="$(json_get_first "$EXCHANGE1_RESPONSE" grant.bearer_token bearer_token || true)"
echo "✓ Workspace 1 launch successful"

echo ""
echo "Writing to workspace 1..."
THREAD1_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $GRANT1_TOKEN" \
  -X POST \
  -d '{
    "thread":{
      "title":"E2E Alpha Thread",
      "type":"incident",
      "status":"active",
      "priority":"p1",
      "tags":["e2e","alpha"],
      "cadence":"daily",
      "current_summary":"alpha workspace thread",
      "next_actions":["verify"],
      "key_artifacts":[],
      "provenance":{"sources":["actor_statement:e2e"]}
    }
  }' \
  "$WS1_BASE_URL/threads")

THREAD1_ID="$(json_get_first "$THREAD1_RESPONSE" thread_id id thread.thread_id thread.id || true)"
echo "✓ Thread created in workspace 1 (id=$THREAD1_ID)"

echo ""
echo "Member launching workspace 2..."
LAUNCH2_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $MEMBER_TOKEN" \
  -X POST \
  -d '{"return_path":"/ws-beta"}' \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS2_ID/launch-sessions")

EXCHANGE_TOKEN2="$(json_get_first "$LAUNCH2_RESPONSE" launch_session.exchange_token exchange_token || true)"
EXCHANGE2_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -X POST \
  -d "{\"exchange_token\":\"$EXCHANGE_TOKEN2\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS2_ID/session-exchange")

GRANT2_TOKEN="$(json_get_first "$EXCHANGE2_RESPONSE" grant.bearer_token bearer_token || true)"
echo "✓ Workspace 2 launch successful"

echo ""
echo "Writing to workspace 2..."
THREAD2_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $GRANT2_TOKEN" \
  -X POST \
  -d '{
    "thread":{
      "title":"E2E Beta Thread",
      "type":"incident",
      "status":"active",
      "priority":"p2",
      "tags":["e2e","beta"],
      "cadence":"weekly",
      "current_summary":"beta workspace thread",
      "next_actions":["verify"],
      "key_artifacts":[],
      "provenance":{"sources":["actor_statement:e2e"]}
    }
  }' \
  "$WS2_BASE_URL/threads")

THREAD2_ID="$(json_get_first "$THREAD2_RESPONSE" thread_id id thread.thread_id thread.id || true)"
echo "✓ Thread created in workspace 2 (id=$THREAD2_ID)"

echo ""
echo "Verifying workspace isolation..."
WS1_THREADS_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $GRANT1_TOKEN" \
  "$WS1_BASE_URL/threads")
WS1_THREAD_COUNT=$(python3 -c "
import json, sys
data = json.load(sys.stdin)
threads = data if isinstance(data, list) else data.get('threads', [])
print(len(threads))
" <<<"$WS1_THREADS_RESPONSE" 2>/dev/null || echo "0")

if [[ "$WS1_THREAD_COUNT" -lt 1 ]]; then
  echo "workspace 1 should have at least one thread" >&2
  exit 1
fi
echo "✓ Workspace isolation verified (ws1 has $WS1_THREAD_COUNT thread(s))"

echo ""
echo "=== Extended flow: Usage tracking ==="

USAGE_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $ADMIN_TOKEN" \
  "$CONTROL_PLANE_BASE_URL/organizations/$ORG_ID/usage-summary")

USAGE_WORKSPACE_COUNT="$(json_get_first "$USAGE_RESPONSE" summary.usage.workspace_count workspace_count || true)"
echo "✓ Usage summary: $USAGE_WORKSPACE_COUNT workspaces"

echo ""
echo "=== Extended flow: Control-plane backup job ==="

BACKUP_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $ADMIN_TOKEN" \
  -X POST \
  -d '{"schedule_name":"e2e-test","retention_days":7}' \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS1_ID/backups")

BACKUP_JOB_STATUS="$(json_get_first "$BACKUP_RESPONSE" provisioning_job.status status || true)"
echo "✓ Backup job: $BACKUP_JOB_STATUS"

echo ""
echo "=== Extended flow: Session revocation ==="

REVOKE_RESPONSE=$(curl -sS \
  -X DELETE \
  -H "authorization: Bearer $ADMIN_TOKEN" \
  "$CONTROL_PLANE_BASE_URL/account/sessions/current")

REVOKE_OK="$(json_get_first "$REVOKE_RESPONSE" revoked ok || true)"
if [[ "$REVOKE_OK" != "true" ]]; then
  echo "session revocation failed" >&2
  exit 1
fi
echo "✓ Session revoked"

echo ""
echo "Verifying revoked session is rejected..."
REVOKED_STATUS=$(curl -sS -o /dev/null -w '%{http_code}' \
  -H "authorization: Bearer $ADMIN_TOKEN" \
  "$CONTROL_PLANE_BASE_URL/organizations" || true)
if [[ "$REVOKED_STATUS" != "401" ]]; then
  echo "expected 401 for revoked session, got $REVOKED_STATUS" >&2
  exit 1
fi
echo "✓ Revoked session rejected"

echo ""
echo "Admin re-login..."
ADMIN_TOKEN=$(login_account "admin@example.com" "$ADMIN_CREDENTIAL_ID")
if [[ -z "$ADMIN_TOKEN" ]]; then
  echo "failed to re-login admin" >&2
  exit 1
fi
echo "✓ Admin re-authenticated"

echo ""
echo "=== Extended flow: Workspace inventory ==="

INVENTORY_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $ADMIN_TOKEN" \
  "$CONTROL_PLANE_BASE_URL/organizations/$ORG_ID/workspace-inventory")

INVENTORY_WS_COUNT=$(python3 -c "
import json, sys
data = json.load(sys.stdin)
workspaces = data.get('workspaces', [])
print(len(workspaces))
" <<<"$INVENTORY_RESPONSE" 2>/dev/null || echo "0")

if [[ "$INVENTORY_WS_COUNT" != "2" ]]; then
  echo "expected 2 workspaces in inventory, got $INVENTORY_WS_COUNT" >&2
  exit 1
fi
echo "✓ Inventory shows $INVENTORY_WS_COUNT workspaces"

echo ""
cat >"$TMP_DIR/summary.txt" <<SUMMARY
control_plane_base_url=${CONTROL_PLANE_BASE_URL}
organization_id=${ORG_ID}
workspace_1_id=${WS1_ID}
workspace_1_base_url=${WS1_BASE_URL}
workspace_1_thread_id=${THREAD1_ID}
workspace_2_id=${WS2_ID}
workspace_2_base_url=${WS2_BASE_URL}
workspace_2_thread_id=${THREAD2_ID}
admin_email=admin@example.com
member_email=member@example.com
usage_workspace_count=${USAGE_WORKSPACE_COUNT}
inventory_workspace_count=${INVENTORY_WS_COUNT}
backup_job_status=${BACKUP_JOB_STATUS}
coverage=control-plane,account,organization,multi-workspace,invite,launch,session-exchange,workspace-rw,workspace-isolation,usage,backup,session-revocation,relogin,inventory
artifacts_dir=${TMP_DIR}
SUMMARY

echo ""
echo "=== SaaS e2e completed successfully ==="
cat "$TMP_DIR/summary.txt"
