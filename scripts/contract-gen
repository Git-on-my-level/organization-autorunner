#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR/core"

go run ./cmd/contract-gen \
  --openapi "../contracts/oar-openapi.yaml" \
  --schema "../contracts/oar-schema.yaml" \
  --out "../contracts/gen" \
  --source-label "contracts/oar-openapi.yaml" \
  --go-module "organization-autorunner-contracts-go-client" \
  --ts-package "organization-autorunner-contracts-ts-client"

go run ./cmd/contract-gen \
  --openapi "../contracts/oar-control-openapi.yaml" \
  --schema "../contracts/oar-schema.yaml" \
  --out "../contracts/gen/control" \
  --source-label "contracts/oar-control-openapi.yaml" \
  --go-module "organization-autorunner-control-contracts-go-client" \
  --ts-package "organization-autorunner-control-contracts-ts-client" \
  --emit-event-ref-rules=false

cd "$ROOT_DIR"

mkdir -p cli/internal/registry
cp contracts/gen/meta/commands.json cli/internal/registry/commands.json
cp contracts/gen/meta/concepts.json cli/internal/registry/concepts.json
cp contracts/gen/meta/help.json cli/internal/registry/help.json
cp contracts/gen/meta/event_ref_rules.json cli/internal/registry/event_ref_rules.json

mkdir -p web-ui/src/lib/generated
cp contracts/gen/meta/event_ref_rules.json web-ui/src/lib/generated/event_ref_rules.json

mkdir -p cli/docs/generated
cp contracts/gen/docs/commands.md cli/docs/generated/commands.md
cp contracts/gen/docs/command-groups.md cli/docs/generated/command-groups.md
cp contracts/gen/docs/concepts.md cli/docs/generated/concepts.md
cp contracts/gen/docs/x-oar-authoring.md cli/docs/generated/x-oar-authoring.md
