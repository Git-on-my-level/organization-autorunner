#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "${SCRIPT_DIR}/hosted/common.sh"

ARTIFACT_DIR="${PACKED_HOST_SMOKE_ARTIFACT_DIR:-$REPO_ROOT/.tmp/packed-host-smoke}"
CONTROL_PLANE_PORT="${CONTROL_PLANE_PORT:-$(pick_loopback_port)}"
CONTROL_PLANE_HOST="127.0.0.1"
CONTROL_PLANE_BASE_URL="http://${CONTROL_PLANE_HOST}:${CONTROL_PLANE_PORT}"
UI_PORT="${UI_PORT:-$(pick_loopback_port)}"
UI_HOST="127.0.0.1"
UI_BASE_URL="http://localhost:${UI_PORT}"
SMOKE_TIMEOUT_SECONDS="${PACKED_HOST_SMOKE_TIMEOUT_SECONDS:-180}"

mkdir -p "$ARTIFACT_DIR"
TMP_DIR="$(mktemp -d "$ARTIFACT_DIR/run.XXXXXX")"
CONTROL_PLANE_LOG="$TMP_DIR/control-plane.log"
WORKSPACE1_LOG="$TMP_DIR/workspace1.log"
WORKSPACE2_LOG="$TMP_DIR/workspace2.log"
UI_LOG="$TMP_DIR/web-ui.log"
UI_COOKIE_JAR="$TMP_DIR/ui-cookies.txt"
CONTROL_PLANE_ROOT="$TMP_DIR/control-plane-root"
WORKSPACE1_ROOT="$TMP_DIR/workspace1-root"
WORKSPACE2_ROOT="$TMP_DIR/workspace2-root"

cleanup() {
  local code=$?
  stop_background_process "${UI_PID:-}"
  stop_background_process "${WORKSPACE2_PID:-}"
  stop_background_process "${WORKSPACE1_PID:-}"
  stop_background_process "${CONTROL_PLANE_PID:-}"

  if [[ $code -ne 0 ]]; then
    echo "packed-host smoke failed; artifacts kept at: $TMP_DIR" >&2
    echo "control-plane log: $CONTROL_PLANE_LOG" >&2
    echo "workspace1 log: $WORKSPACE1_LOG" >&2
    echo "workspace2 log: $WORKSPACE2_LOG" >&2
    echo "web-ui log: $UI_LOG" >&2
  else
    echo "packed-host smoke artifacts: $TMP_DIR"
  fi
}
trap cleanup EXIT INT TERM

require_command curl go python3 pnpm node

assert_http_status() {
  local expected_status="$1"
  local actual_status="$2"
  local context="$3"
  if [[ "$expected_status" != "$actual_status" ]]; then
    echo "assertion failed: expected HTTP $expected_status, got $actual_status ($context)" >&2
    exit 1
  fi
}

json_get() {
  local json="$1"
  local path="$2"
  python3 "${REPO_ROOT}/scripts/hosted/json-tool.py" get "$path" <<<"$json"
}

json_get_first() {
  local json="$1"
  shift
  local path value
  for path in "$@"; do
    if value="$(json_get "$json" "$path" 2>/dev/null)"; then
      printf '%s\n' "$value"
      return 0
    fi
  done
  return 1
}

invite_token_from_url() {
  local invite_url="$1"
  python3 -c '
import sys
from urllib.parse import urlparse

path = urlparse(sys.argv[1]).path.rstrip("/")
prefix = "/invites/"
if not path.startswith(prefix):
    raise SystemExit(1)
print(path[len(prefix):])
' "$invite_url"
}

generate_ed25519_key_base64() {
  local go_file
  go_file="$(mktemp "${TMP_DIR}/genkey.XXXXXX.go")"
  cat >"$go_file" <<'EOF'
package main
import (
	"crypto/ed25519"
	"crypto/rand"
	"encoding/base64"
	"fmt"
	"os"
)
func main() {
	publicKey, privateKey, err := ed25519.GenerateKey(rand.Reader)
	if err != nil {
		fmt.Fprintf(os.Stderr, "failed to generate key: %v\n", err)
		os.Exit(1)
	}
	fmt.Println(base64.StdEncoding.EncodeToString(publicKey))
	fmt.Println(base64.StdEncoding.EncodeToString(privateKey))
}
EOF
  go run "$go_file"
  rm -f "$go_file"
}

sign_heartbeat_token() {
  local workspace_id="$1"
  local service_identity_id="$2"
  local private_key="$3"
  local go_file
  go_file="$(mktemp "${TMP_DIR}/heartbeattoken.XXXXXX.go")"
  cat >"$go_file" <<EOF
package main
import (
	"crypto/ed25519"
	"encoding/base64"
	"fmt"
	"os"
	"time"
	"github.com/golang-jwt/jwt/v5"
)
func main() {
	privateKeyBytes, _ := base64.StdEncoding.DecodeString("$private_key")
	privateKey := ed25519.PrivateKey(privateKeyBytes)
	now := time.Now()
	claims := jwt.MapClaims{
		"iss": "$service_identity_id",
		"sub": "$service_identity_id",
		"aud": "oar-control-plane",
		"iat": now.Unix(),
		"exp": now.Add(10 * time.Minute).Unix(),
		"workspace_id": "$workspace_id",
		"purpose": "heartbeat",
	}
	token := jwt.NewWithClaims(jwt.SigningMethodEdDSA, claims)
	signed, err := token.SignedString(privateKey)
	if err != nil {
		fmt.Fprintf(os.Stderr, "failed to sign: %v\n", err)
		os.Exit(1)
	}
	fmt.Println(signed)
}
EOF
  (cd "$REPO_ROOT/core" && go run "$go_file")
  rm -f "$go_file"
}

echo "Building core binary..."
CORE_BIN="$(build_core_binary "$TMP_DIR/oar-core")"
SCHEMA_PATH="$(resolve_schema_path)"

echo "Generating workspace service identity key pair..."
KEYS=$(generate_ed25519_key_base64)
SERVICE_PUBLIC_KEY=$(echo "$KEYS" | sed -n '1p')
SERVICE_PRIVATE_KEY=$(echo "$KEYS" | sed -n '2p')

echo ""
echo "=== Step 1: Starting control plane ==="

mkdir -p "$CONTROL_PLANE_ROOT"
(
  export OAR_CONTROL_PLANE_WEBAUTHN_RPID="localhost"
  export OAR_CONTROL_PLANE_WEBAUTHN_ORIGIN="http://localhost:${UI_PORT}"
  export OAR_CONTROL_PLANE_WORKSPACE_GRANT_ISSUER="$CONTROL_PLANE_BASE_URL"
  export OAR_CONTROL_PLANE_WORKSPACE_GRANT_AUDIENCE="oar-core"
  export OAR_CONTROL_PLANE_WORKSPACE_GRANT_SIGNING_KEY="$SERVICE_PRIVATE_KEY"
  export OAR_CONTROL_PLANE_WORKSPACE_URL_TEMPLATE="${UI_BASE_URL}/%s"
  export OAR_CONTROL_PLANE_INVITE_URL_TEMPLATE="${CONTROL_PLANE_BASE_URL}/invites/%s"
  cd "$REPO_ROOT/core"
  go run ./cmd/oar-control-plane \
    --listen-addr "${CONTROL_PLANE_HOST}:${CONTROL_PLANE_PORT}" \
    --workspace-root "$CONTROL_PLANE_ROOT" \
    >"$CONTROL_PLANE_LOG" 2>&1
) &
CONTROL_PLANE_PID=$!

if ! wait_for_http_ok "$CONTROL_PLANE_BASE_URL/readyz" "$SMOKE_TIMEOUT_SECONDS"; then
  echo "control plane did not become healthy" >&2
  cat "$CONTROL_PLANE_LOG" >&2 || true
  exit 1
fi

echo "✓ Control plane started at $CONTROL_PLANE_BASE_URL"

echo ""
echo "=== Step 2: Account registration (mock passkey) ==="

MOCK_EMAIL="packed-host-owner@example.com"
MOCK_DISPLAY_NAME="Packed Host Owner"

START_REG_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "origin: http://localhost:${UI_PORT}" \
  -X POST \
  -d "{\"email\":\"$MOCK_EMAIL\",\"display_name\":\"$MOCK_DISPLAY_NAME\"}" \
  "$CONTROL_PLANE_BASE_URL/account/passkeys/registrations/start")

REG_SESSION_ID="$(json_get_first "$START_REG_RESPONSE" registration_session_id id || true)"
if [[ -z "$REG_SESSION_ID" ]]; then
  echo "failed to extract registration session id" >&2
  echo "response: $START_REG_RESPONSE" >&2
  exit 1
fi

REG_OPTIONS="$(json_get "$START_REG_RESPONSE" public_key_options || true)"
CHALLENGE="$(json_get "$REG_OPTIONS" challenge || true)"
REG_USER_ID="$(json_get_first "$REG_OPTIONS" user.id id || true)"
if [[ -z "$CHALLENGE" ]] || [[ -z "$REG_USER_ID" ]]; then
  echo "failed to extract challenge or user id from registration options" >&2
  echo "options: $REG_OPTIONS" >&2
  exit 1
fi

MOCK_CREDENTIAL_ID="packed-host-cred-$(generate_token 8)"
CLIENT_DATA=$(python3 -c "
import json, base64
data = {'challenge': '$CHALLENGE', 'origin': 'http://localhost:${UI_PORT}', 'type': 'webauthn.create'}
print(base64.urlsafe_b64encode(json.dumps(data).encode()).decode().rstrip('='))
")

FINISH_REG_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "origin: http://localhost:${UI_PORT}" \
  -X POST \
  -d "{\"registration_session_id\":\"$REG_SESSION_ID\",\"credential\":{\"id\":\"$MOCK_CREDENTIAL_ID\",\"rawId\":\"$MOCK_CREDENTIAL_ID\",\"type\":\"public-key\",\"response\":{\"clientDataJSON\":\"$CLIENT_DATA\",\"userHandle\":\"$REG_USER_ID\"}}}" \
  "$CONTROL_PLANE_BASE_URL/account/passkeys/registrations/finish")

OWNER_TOKEN="$(json_get_first "$FINISH_REG_RESPONSE" session.access_token access_token tokens.access_token || true)"
if [[ -z "$OWNER_TOKEN" ]]; then
  echo "failed to extract access token from registration" >&2
  echo "response: $FINISH_REG_RESPONSE" >&2
  exit 1
fi

echo "✓ Account registered (email=$MOCK_EMAIL)"

echo ""
echo "=== Step 3: Organization creation ==="

CREATE_ORG_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $OWNER_TOKEN" \
  -X POST \
  -d '{"slug":"packed-host-org","display_name":"Packed Host Org","plan_tier":"team"}' \
  "$CONTROL_PLANE_BASE_URL/organizations")

ORG_ID="$(json_get_first "$CREATE_ORG_RESPONSE" organization.id id || true)"
if [[ -z "$ORG_ID" ]]; then
  echo "failed to extract organization id" >&2
  echo "response: $CREATE_ORG_RESPONSE" >&2
  exit 1
fi

echo "✓ Organization created (id=$ORG_ID)"

echo ""
echo "=== Step 4: Workspace 1 provisioning ==="

WORKSPACE1_SERVICE_IDENTITY_ID="packed-host-ws1-service"
CREATE_WS1_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $OWNER_TOKEN" \
  -X POST \
  -d "{\"organization_id\":\"$ORG_ID\",\"slug\":\"packed-ws-alpha\",\"display_name\":\"Packed Alpha\",\"region\":\"us-central1\",\"workspace_tier\":\"standard\",\"service_identity_id\":\"$WORKSPACE1_SERVICE_IDENTITY_ID\",\"service_identity_public_key\":\"$SERVICE_PUBLIC_KEY\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces")

WS1_ID="$(json_get_first "$CREATE_WS1_RESPONSE" workspace.id id || true)"
WS1_DEPLOYMENT_ROOT="$(json_get_first "$CREATE_WS1_RESPONSE" workspace.deployment_root deployment_root || true)"
WORKSPACE1_PORT="$(json_get_first "$CREATE_WS1_RESPONSE" workspace.listen_port listen_port || true)"
WS1_JOB_ID="$(json_get_first "$CREATE_WS1_RESPONSE" provisioning_job.id job_id || true)"
if [[ -z "$WS1_ID" ]] || [[ -z "$WS1_DEPLOYMENT_ROOT" ]] || [[ -z "$WORKSPACE1_PORT" ]]; then
  echo "failed to extract workspace 1 id, deployment root, or listen port" >&2
  echo "response: $CREATE_WS1_RESPONSE" >&2
  exit 1
fi

WS1_STATUS="$(json_get_first "$CREATE_WS1_RESPONSE" workspace.status status || true)"
if [[ "$WS1_STATUS" != "provisioned" ]] && [[ "$WS1_STATUS" != "active" ]] && [[ "$WS1_STATUS" != "ready" ]]; then
  echo "workspace 1 provisioning did not reach active state: $WS1_STATUS" >&2
  printf '%s\n' "$CREATE_WS1_RESPONSE" >&2
  exit 1
fi

echo "✓ Workspace 1 provisioned (id=$WS1_ID, slug=packed-ws-alpha)"

echo ""
echo "=== Step 5: Workspace 2 provisioning ==="

WORKSPACE2_SERVICE_IDENTITY_ID="packed-host-ws2-service"
CREATE_WS2_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $OWNER_TOKEN" \
  -X POST \
  -d "{\"organization_id\":\"$ORG_ID\",\"slug\":\"packed-ws-beta\",\"display_name\":\"Packed Beta\",\"region\":\"us-east1\",\"workspace_tier\":\"plus\",\"service_identity_id\":\"$WORKSPACE2_SERVICE_IDENTITY_ID\",\"service_identity_public_key\":\"$SERVICE_PUBLIC_KEY\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces")

WS2_ID="$(json_get_first "$CREATE_WS2_RESPONSE" workspace.id id || true)"
WS2_DEPLOYMENT_ROOT="$(json_get_first "$CREATE_WS2_RESPONSE" workspace.deployment_root deployment_root || true)"
WORKSPACE2_PORT="$(json_get_first "$CREATE_WS2_RESPONSE" workspace.listen_port listen_port || true)"
if [[ -z "$WS2_ID" ]] || [[ -z "$WS2_DEPLOYMENT_ROOT" ]] || [[ -z "$WORKSPACE2_PORT" ]]; then
  echo "failed to extract workspace 2 id, deployment root, or listen port" >&2
  echo "response: $CREATE_WS2_RESPONSE" >&2
  exit 1
fi

echo "✓ Workspace 2 provisioned (id=$WS2_ID, slug=packed-ws-beta)"

echo ""
echo "=== Step 6: Starting workspace cores ==="

mkdir -p "$WORKSPACE1_ROOT"
mkdir -p "$WORKSPACE2_ROOT"

BOOTSTRAP_TOKEN1="packed-host-ws1-$(generate_token 16)"
export OAR_HUMAN_AUTH_MODE="control_plane"
export OAR_CONTROL_PLANE_TOKEN_ISSUER="$CONTROL_PLANE_BASE_URL"
export OAR_CONTROL_PLANE_TOKEN_AUDIENCE="oar-core"
export OAR_CONTROL_PLANE_TOKEN_PUBLIC_KEY="$SERVICE_PUBLIC_KEY"
export OAR_CONTROL_PLANE_WORKSPACE_ID="$WS1_ID"
export OAR_WORKSPACE_SERVICE_ID="$WORKSPACE1_SERVICE_IDENTITY_ID"
export OAR_WORKSPACE_SERVICE_PRIVATE_KEY="$SERVICE_PRIVATE_KEY"

start_core_server \
  WORKSPACE1_PID \
  "$CORE_BIN" \
  "$WS1_DEPLOYMENT_ROOT/workspace" \
  "$SCHEMA_PATH" \
  "$CONTROL_PLANE_HOST" \
  "$WORKSPACE1_PORT" \
  "$WORKSPACE1_LOG" \
  "packed-ws1-instance" \
  set \
  "$BOOTSTRAP_TOKEN1" \
  false \
  false \
  false

BOOTSTRAP_TOKEN2="packed-host-ws2-$(generate_token 16)"
export OAR_CONTROL_PLANE_WORKSPACE_ID="$WS2_ID"
export OAR_WORKSPACE_SERVICE_ID="$WORKSPACE2_SERVICE_IDENTITY_ID"
export OAR_WORKSPACE_SERVICE_PRIVATE_KEY="$SERVICE_PRIVATE_KEY"

start_core_server \
  WORKSPACE2_PID \
  "$CORE_BIN" \
  "$WS2_DEPLOYMENT_ROOT/workspace" \
  "$SCHEMA_PATH" \
  "$CONTROL_PLANE_HOST" \
  "$WORKSPACE2_PORT" \
  "$WORKSPACE2_LOG" \
  "packed-ws2-instance" \
  set \
  "$BOOTSTRAP_TOKEN2" \
  false \
  false \
  false

WS1_BASE_URL="http://${CONTROL_PLANE_HOST}:${WORKSPACE1_PORT}"
WS2_BASE_URL="http://${CONTROL_PLANE_HOST}:${WORKSPACE2_PORT}"

if ! wait_for_http_ok "$WS1_BASE_URL/readyz" 30; then
  echo "workspace 1 did not become healthy" >&2
  cat "$WORKSPACE1_LOG" >&2 || true
  exit 1
fi

if ! wait_for_http_ok "$WS2_BASE_URL/readyz" 30; then
  echo "workspace 2 did not become healthy" >&2
  cat "$WORKSPACE2_LOG" >&2 || true
  exit 1
fi

unset OAR_HUMAN_AUTH_MODE
unset OAR_CONTROL_PLANE_TOKEN_ISSUER
unset OAR_CONTROL_PLANE_TOKEN_AUDIENCE
unset OAR_CONTROL_PLANE_TOKEN_PUBLIC_KEY
unset OAR_CONTROL_PLANE_WORKSPACE_ID
unset OAR_WORKSPACE_SERVICE_ID
unset OAR_WORKSPACE_SERVICE_PRIVATE_KEY

echo "✓ Both workspace cores started and healthy"

echo ""
echo "=== Step 7: Verifying control-plane routing metadata ==="

WS1_WORKSPACE_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $OWNER_TOKEN" \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS1_ID")
WS2_WORKSPACE_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $OWNER_TOKEN" \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS2_ID")

WS1_CORE_ORIGIN="$(json_get_first "$WS1_WORKSPACE_RESPONSE" workspace.core_origin core_origin || true)"
WS2_CORE_ORIGIN="$(json_get_first "$WS2_WORKSPACE_RESPONSE" workspace.core_origin core_origin || true)"
if [[ "$WS1_CORE_ORIGIN" != "$WS1_BASE_URL" ]]; then
  echo "workspace 1 core_origin mismatch: expected $WS1_BASE_URL, got $WS1_CORE_ORIGIN" >&2
  echo "response: $WS1_WORKSPACE_RESPONSE" >&2
  exit 1
fi
if [[ "$WS2_CORE_ORIGIN" != "$WS2_BASE_URL" ]]; then
  echo "workspace 2 core_origin mismatch: expected $WS2_BASE_URL, got $WS2_CORE_ORIGIN" >&2
  echo "response: $WS2_WORKSPACE_RESPONSE" >&2
  exit 1
fi

echo "✓ Control-plane routing metadata matches workspace listeners"

echo ""
echo "=== Step 8: Building shared web UI ==="

(
  cd "$REPO_ROOT/web-ui"
  ./scripts/build >"$UI_LOG" 2>&1
) || {
  echo "web UI build failed" >&2
  cat "$UI_LOG" >&2 || true
  exit 1
}

echo "✓ Shared web UI built"

echo ""
echo "=== Step 8b: Starting shared web UI ==="

(
  cd "$REPO_ROOT/web-ui"
  HOST="$UI_HOST" \
  PORT="$UI_PORT" \
  ORIGIN="$UI_BASE_URL" \
  OAR_CONTROL_BASE_URL="$CONTROL_PLANE_BASE_URL" \
  OAR_CORE_BASE_URL="" \
  ./scripts/serve >>"$UI_LOG" 2>&1
) &
UI_PID=$!

if ! wait_for_http_ok "$UI_BASE_URL/" 60; then
  echo "web UI did not become healthy" >&2
  cat "$UI_LOG" >&2 || true
  exit 1
fi

echo "✓ Shared web UI started at $UI_BASE_URL"

echo ""
echo "=== Step 8c: Shared web UI login ==="

START_UI_LOGIN_RESPONSE=$(curl -sS \
  -c "$UI_COOKIE_JAR" \
  -b "$UI_COOKIE_JAR" \
  -H "content-type: application/json" \
  -H "origin: $UI_BASE_URL" \
  -X POST \
  -d "{\"action\":\"login-start\",\"email\":\"$MOCK_EMAIL\"}" \
  "$UI_BASE_URL/auth")

UI_LOGIN_SESSION_ID="$(json_get_first "$START_UI_LOGIN_RESPONSE" session_id id || true)"
UI_LOGIN_OPTIONS="$(json_get "$START_UI_LOGIN_RESPONSE" public_key_options || true)"
UI_LOGIN_CHALLENGE="$(json_get "$UI_LOGIN_OPTIONS" challenge || true)"
if [[ -z "$UI_LOGIN_SESSION_ID" ]] || [[ -z "$UI_LOGIN_CHALLENGE" ]]; then
  echo "failed to start UI login" >&2
  echo "response: $START_UI_LOGIN_RESPONSE" >&2
  exit 1
fi

UI_LOGIN_CLIENT_DATA=$(python3 -c "
import json, base64
data = {'challenge': '$UI_LOGIN_CHALLENGE', 'origin': '$UI_BASE_URL', 'type': 'webauthn.get'}
print(base64.urlsafe_b64encode(json.dumps(data).encode()).decode().rstrip('='))
")

FINISH_UI_LOGIN_RESPONSE=$(curl -sS \
  -c "$UI_COOKIE_JAR" \
  -b "$UI_COOKIE_JAR" \
  -H "content-type: application/json" \
  -H "origin: $UI_BASE_URL" \
  -X POST \
  -d "{\"action\":\"login-finish\",\"session_id\":\"$UI_LOGIN_SESSION_ID\",\"credential\":{\"id\":\"$MOCK_CREDENTIAL_ID\",\"rawId\":\"$MOCK_CREDENTIAL_ID\",\"type\":\"public-key\",\"response\":{\"clientDataJSON\":\"$UI_LOGIN_CLIENT_DATA\"}}}" \
  "$UI_BASE_URL/auth")

UI_CONTROL_TOKEN="$(json_get_first "$FINISH_UI_LOGIN_RESPONSE" session.access_token access_token || true)"
if [[ -z "$UI_CONTROL_TOKEN" ]]; then
  echo "failed to finish UI login" >&2
  echo "response: $FINISH_UI_LOGIN_RESPONSE" >&2
  exit 1
fi

UI_DASHBOARD_STATUS=$(curl -sS -o /dev/null -w '%{http_code}' \
  -b "$UI_COOKIE_JAR" \
  "$UI_BASE_URL/dashboard" || true)
assert_http_status "200" "$UI_DASHBOARD_STATUS" "shared web UI dashboard"

echo "✓ Shared web UI login succeeded"

echo ""
echo "=== Step 9: Direct workspace launch and session exchange ==="

LAUNCH_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $OWNER_TOKEN" \
  -X POST \
  -d '{"return_path":"/packed-ws-alpha"}' \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS1_ID/launch-sessions")

EXCHANGE_TOKEN="$(json_get_first "$LAUNCH_RESPONSE" launch_session.exchange_token exchange_token || true)"
if [[ -z "$EXCHANGE_TOKEN" ]]; then
  echo "failed to extract exchange token from launch session" >&2
  echo "response: $LAUNCH_RESPONSE" >&2
  exit 1
fi

echo "Launch session created"

EXCHANGE_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -X POST \
  -d "{\"exchange_token\":\"$EXCHANGE_TOKEN\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS1_ID/session-exchange")

WORKSPACE_GRANT_TOKEN="$(json_get_first "$EXCHANGE_RESPONSE" grant.bearer_token bearer_token access_token || true)"
if [[ -z "$WORKSPACE_GRANT_TOKEN" ]]; then
  echo "failed to extract workspace grant token" >&2
  echo "response: $EXCHANGE_RESPONSE" >&2
  exit 1
fi

echo "✓ Session exchange complete, workspace grant issued"

echo ""
echo "=== Step 10: Workspace read/write ==="

THREAD_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $WORKSPACE_GRANT_TOKEN" \
  -X POST \
  -d '{
    "thread":{
      "title":"Packed host smoke thread",
      "type":"incident",
      "status":"active",
      "priority":"p1",
      "tags":["packed-host","smoke"],
      "cadence":"daily",
      "current_summary":"packed host smoke test",
      "next_actions":["verify"],
      "key_artifacts":[],
      "provenance":{"sources":["actor_statement:packed-host-smoke"]}
    }
  }' \
  "$WS1_BASE_URL/threads")

THREAD_ID="$(json_get_first "$THREAD_RESPONSE" thread_id id thread.thread_id thread.id || true)"
if [[ -z "$THREAD_ID" ]]; then
  echo "failed to extract thread id" >&2
  echo "response: $THREAD_RESPONSE" >&2
  exit 1
fi

THREADS_READ_STATUS=$(curl -sS -o /dev/null -w '%{http_code}' \
  -H "authorization: Bearer $WORKSPACE_GRANT_TOKEN" \
  "$WS1_BASE_URL/threads" || true)
assert_http_status "200" "$THREADS_READ_STATUS" "authenticated /threads read"

THREAD_READ_STATUS=$(curl -sS -o /dev/null -w '%{http_code}' \
  -H "authorization: Bearer $WORKSPACE_GRANT_TOKEN" \
  "$WS1_BASE_URL/threads/$THREAD_ID" || true)
assert_http_status "200" "$THREAD_READ_STATUS" "authenticated thread read"

ME_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $WORKSPACE_GRANT_TOKEN" \
  "$WS1_BASE_URL/agents/me")

OWNER_ACTOR_ID="$(json_get_first "$ME_RESPONSE" agent.actor_id actor_id || true)"
if [[ -z "$OWNER_ACTOR_ID" ]]; then
  echo "failed to extract actor id from /agents/me" >&2
  echo "response: $ME_RESPONSE" >&2
  exit 1
fi

echo "✓ Workspace read/write works (thread_id=$THREAD_ID)"

echo ""
echo "=== Step 10a: Shared web UI launch ==="

UI_LAUNCH_RESPONSE=$(curl -sS \
  -c "$UI_COOKIE_JAR" \
  -b "$UI_COOKIE_JAR" \
  -H "content-type: application/json" \
  -H "origin: $UI_BASE_URL" \
  -X POST \
  -d "{\"workspace_id\":\"$WS1_ID\",\"return_path\":\"/threads/$THREAD_ID\"}" \
  "$UI_BASE_URL/dashboard/launch")

UI_REDIRECT_TO="$(json_get_first "$UI_LAUNCH_RESPONSE" redirect_to || true)"
if [[ "$UI_REDIRECT_TO" != "/packed-ws-alpha/threads/$THREAD_ID" ]]; then
  echo "unexpected UI launch redirect: $UI_REDIRECT_TO" >&2
  echo "response: $UI_LAUNCH_RESPONSE" >&2
  exit 1
fi

UI_THREAD_PAGE_STATUS=$(curl -sS -o "$TMP_DIR/ui-thread-page.html" -w '%{http_code}' \
  -b "$UI_COOKIE_JAR" \
  "$UI_BASE_URL$UI_REDIRECT_TO" || true)
assert_http_status "200" "$UI_THREAD_PAGE_STATUS" "shared web UI thread page"

UI_PROXY_THREAD_STATUS=$(curl -sS -o "$TMP_DIR/ui-thread.json" -w '%{http_code}' \
  -b "$UI_COOKIE_JAR" \
  -H "x-oar-workspace-slug: packed-ws-alpha" \
  "$UI_BASE_URL/threads/$THREAD_ID" || true)
assert_http_status "200" "$UI_PROXY_THREAD_STATUS" "shared web UI proxied thread read"
grep -F "\"$THREAD_ID\"" "$TMP_DIR/ui-thread.json" >/dev/null || {
  echo "shared web UI proxied thread response missing thread id $THREAD_ID" >&2
  cat "$TMP_DIR/ui-thread.json" >&2 || true
  exit 1
}

echo "✓ Shared web UI launch and proxied thread read succeeded"

echo ""
echo "=== Step 10b: Create artifact for backup verification ==="

ARTIFACT_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $WORKSPACE_GRANT_TOKEN" \
  -X POST \
  -d "{\"actor_id\":\"$OWNER_ACTOR_ID\",\"artifact\":{\"kind\":\"evidence\",\"refs\":[]},\"content\":\"packed-host-smoke-artifact-content\",\"content_type\":\"text/plain\"}" \
  "$WS1_BASE_URL/artifacts")

ARTIFACT_ID="$(json_get_first "$ARTIFACT_RESPONSE" artifact.id artifact_id id || true)"
if [[ -z "$ARTIFACT_ID" ]]; then
  echo "failed to create artifact" >&2
  echo "response: $ARTIFACT_RESPONSE" >&2
  exit 1
fi

echo "✓ Artifact created (id=$ARTIFACT_ID)"

echo ""
echo "=== Step 11: Heartbeat visibility ==="

HEARTBEAT_TOKEN=$(sign_heartbeat_token "$WS1_ID" "$WORKSPACE1_SERVICE_IDENTITY_ID" "$SERVICE_PRIVATE_KEY")

HEARTBEAT_PAYLOAD=$(cat <<EOF
{
  "version": "packed-host-smoke/v1",
  "build": "smoke-build",
  "health_summary": {"status": "healthy", "checks": {"db": "ok", "storage": "ok"}},
  "projection_maintenance_summary": {"last_run": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")"},
  "usage_summary": {"storage_gb": 1, "thread_count": 1}
}
EOF
)

HEARTBEAT_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $HEARTBEAT_TOKEN" \
  -X POST \
  -d "$HEARTBEAT_PAYLOAD" \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS1_ID/heartbeat")

HEARTBEAT_WORKSPACE="$(json_get_first "$HEARTBEAT_RESPONSE" workspace || true)"
HEARTBEAT_VERSION="$(json_get_first "$HEARTBEAT_WORKSPACE" heartbeat_version || true)"
if [[ "$HEARTBEAT_VERSION" != "packed-host-smoke/v1" ]]; then
  echo "heartbeat version mismatch: expected packed-host-smoke/v1, got $HEARTBEAT_VERSION" >&2
  echo "response: $HEARTBEAT_RESPONSE" >&2
  exit 1
fi

echo "✓ Heartbeat recorded (version=$HEARTBEAT_VERSION)"

INVENTORY_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $OWNER_TOKEN" \
  "$CONTROL_PLANE_BASE_URL/organizations/$ORG_ID/workspace-inventory")

INVENTORY_WS1_HEARTBEAT_VERSION="$(python3 -c "
import json, sys
data = json.load(sys.stdin)
workspaces = data.get('workspaces', [])
for entry in workspaces:
    ws = entry.get('workspace', entry)
    if ws.get('id') == '$WS1_ID':
        print(ws.get('heartbeat_version', ''))
        break
" <<<"$INVENTORY_RESPONSE" 2>/dev/null || true)"

if [[ "$INVENTORY_WS1_HEARTBEAT_VERSION" != "packed-host-smoke/v1" ]]; then
  echo "inventory heartbeat version mismatch: expected packed-host-smoke/v1, got $INVENTORY_WS1_HEARTBEAT_VERSION" >&2
  echo "response: $INVENTORY_RESPONSE" >&2
  exit 1
fi

echo "✓ Heartbeat visible in workspace inventory"

echo ""
echo "=== Step 12: Backup and restore path ==="

BACKUP_DIR="${TMP_DIR}/backup-ws1"
mkdir -p "$BACKUP_DIR"

BACKUP_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $OWNER_TOKEN" \
  -X POST \
  -d '{"schedule_name":"packed-host-smoke","retention_days":7}' \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS1_ID/backups")

BACKUP_JOB_ID="$(json_get_first "$BACKUP_RESPONSE" provisioning_job.id job_id || true)"
BACKUP_JOB_STATUS="$(json_get_first "$BACKUP_RESPONSE" provisioning_job.status status || true)"

if [[ -z "$BACKUP_JOB_ID" ]]; then
  echo "failed to create backup job" >&2
  echo "response: $BACKUP_RESPONSE" >&2
  exit 1
fi

echo "Backup job created (id=$BACKUP_JOB_ID, status=$BACKUP_JOB_STATUS)"

"${SCRIPT_DIR}/hosted/backup-workspace.sh" \
  --instance-root "$WS1_DEPLOYMENT_ROOT" \
  --output-dir "$BACKUP_DIR" \
  --include-config-secrets

if [[ ! -f "$BACKUP_DIR/manifest.env" ]]; then
  echo "backup manifest not created" >&2
  exit 1
fi

BACKUP_ARTIFACT_COUNT="$(manifest_get "$BACKUP_DIR/manifest.env" ARTIFACT_COUNT || true)"
if [[ "$BACKUP_ARTIFACT_COUNT" -lt 1 ]]; then
  echo "backup should contain at least one artifact (got $BACKUP_ARTIFACT_COUNT)" >&2
  exit 1
fi

echo "✓ Backup created (artifacts=$BACKUP_ARTIFACT_COUNT)"

RESTORE_DRILL_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $OWNER_TOKEN" \
  -X POST \
  -d "{\"backup_dir\":\"$BACKUP_DIR\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces/$WS1_ID/restore-drills")

RESTORE_DRILL_JOB_ID="$(json_get_first "$RESTORE_DRILL_RESPONSE" provisioning_job.id job_id || true)"
RESTORE_DRILL_JOB_STATUS="$(json_get_first "$RESTORE_DRILL_RESPONSE" provisioning_job.status status || true)"
if [[ -z "$RESTORE_DRILL_JOB_ID" ]] || [[ "$RESTORE_DRILL_JOB_STATUS" != "succeeded" ]]; then
  echo "restore drill did not succeed" >&2
  echo "response: $RESTORE_DRILL_RESPONSE" >&2
  exit 1
fi

echo "✓ Restore drill recorded (job_id=$RESTORE_DRILL_JOB_ID)"

RESTORED_ROOT="${TMP_DIR}/restored-ws1"
RESTORED_SERVICE_IDENTITY_ID="packed-host-restored-service"

KEYS_RESTORED=$(generate_ed25519_key_base64)
RESTORED_PUBLIC_KEY=$(echo "$KEYS_RESTORED" | sed -n '1p')
RESTORED_PRIVATE_KEY=$(echo "$KEYS_RESTORED" | sed -n '2p')

CREATE_RESTORED_WS_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $OWNER_TOKEN" \
  -X POST \
  -d "{\"organization_id\":\"$ORG_ID\",\"slug\":\"packed-ws-restored\",\"display_name\":\"Packed Restored\",\"region\":\"us-central1\",\"workspace_tier\":\"standard\",\"service_identity_id\":\"$RESTORED_SERVICE_IDENTITY_ID\",\"service_identity_public_key\":\"$RESTORED_PUBLIC_KEY\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces")

RESTORED_WS_ID="$(json_get_first "$CREATE_RESTORED_WS_RESPONSE" workspace.id id || true)"
RESTORED_DEPLOYMENT_ROOT="$(json_get_first "$CREATE_RESTORED_WS_RESPONSE" workspace.deployment_root deployment_root || true)"
RESTORED_PORT="$(json_get_first "$CREATE_RESTORED_WS_RESPONSE" workspace.listen_port listen_port || true)"

if [[ -z "$RESTORED_WS_ID" ]] || [[ -z "$RESTORED_DEPLOYMENT_ROOT" ]] || [[ -z "$RESTORED_PORT" ]]; then
  echo "failed to extract restored workspace id, deployment root, or listen port" >&2
  echo "response: $CREATE_RESTORED_WS_RESPONSE" >&2
  exit 1
fi

echo "Restored workspace provisioned (id=$RESTORED_WS_ID)"

"${SCRIPT_DIR}/hosted/restore-workspace.sh" \
  --backup-dir "$BACKUP_DIR" \
  --target-instance-root "$RESTORED_DEPLOYMENT_ROOT" \
  --instance "packed-ws-restored" \
  --public-origin "http://localhost:${RESTORED_PORT}" \
  --listen-port "$RESTORED_PORT" \
  --web-ui-port "$UI_PORT" \
  --bootstrap-token-mode clear \
  --force

if [[ ! -f "${RESTORED_DEPLOYMENT_ROOT}/metadata/restore-receipt.env" ]]; then
  echo "restore receipt not created" >&2
  exit 1
fi

echo "✓ Restore completed"

BOOTSTRAP_TOKEN_RESTORED="packed-host-restored-$(generate_token 16)"
RESTORED_LOG="$TMP_DIR/restored.log"
export OAR_HUMAN_AUTH_MODE="control_plane"
export OAR_CONTROL_PLANE_TOKEN_ISSUER="$CONTROL_PLANE_BASE_URL"
export OAR_CONTROL_PLANE_TOKEN_AUDIENCE="oar-core"
export OAR_CONTROL_PLANE_TOKEN_PUBLIC_KEY="$SERVICE_PUBLIC_KEY"
export OAR_CONTROL_PLANE_WORKSPACE_ID="$RESTORED_WS_ID"
export OAR_WORKSPACE_SERVICE_ID="$RESTORED_SERVICE_IDENTITY_ID"
export OAR_WORKSPACE_SERVICE_PRIVATE_KEY="$RESTORED_PRIVATE_KEY"

RESTORED_PID=""
start_core_server \
  RESTORED_PID \
  "$CORE_BIN" \
  "${RESTORED_DEPLOYMENT_ROOT}/workspace" \
  "$SCHEMA_PATH" \
  "$CONTROL_PLANE_HOST" \
  "$RESTORED_PORT" \
  "$RESTORED_LOG" \
  "packed-ws-restored-instance" \
  set \
  "$BOOTSTRAP_TOKEN_RESTORED" \
  false \
  false \
  false

unset OAR_HUMAN_AUTH_MODE
unset OAR_CONTROL_PLANE_TOKEN_ISSUER
unset OAR_CONTROL_PLANE_TOKEN_AUDIENCE
unset OAR_CONTROL_PLANE_TOKEN_PUBLIC_KEY
unset OAR_CONTROL_PLANE_WORKSPACE_ID
unset OAR_WORKSPACE_SERVICE_ID
unset OAR_WORKSPACE_SERVICE_PRIVATE_KEY

RESTORED_BASE_URL="http://${CONTROL_PLANE_HOST}:${RESTORED_PORT}"
if ! wait_for_http_ok "$RESTORED_BASE_URL/readyz" 30; then
  echo "restored workspace did not become healthy" >&2
  cat "$RESTORED_LOG" >&2 || true
  exit 1
fi

echo "✓ Restored workspace core started"

LAUNCH_RESTORED_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -H "authorization: Bearer $OWNER_TOKEN" \
  -X POST \
  -d '{"return_path":"/packed-ws-restored"}' \
  "$CONTROL_PLANE_BASE_URL/workspaces/$RESTORED_WS_ID/launch-sessions")

RESTORED_EXCHANGE_TOKEN="$(json_get_first "$LAUNCH_RESTORED_RESPONSE" launch_session.exchange_token exchange_token || true)"
RESTORED_EXCHANGE_RESPONSE=$(curl -sS \
  -H "content-type: application/json" \
  -X POST \
  -d "{\"exchange_token\":\"$RESTORED_EXCHANGE_TOKEN\"}" \
  "$CONTROL_PLANE_BASE_URL/workspaces/$RESTORED_WS_ID/session-exchange")

RESTORED_GRANT_TOKEN="$(json_get_first "$RESTORED_EXCHANGE_RESPONSE" grant.bearer_token bearer_token access_token || true)"

RESTORED_THREAD_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $RESTORED_GRANT_TOKEN" \
  "$RESTORED_BASE_URL/threads/$THREAD_ID")

RESTORED_THREAD_TITLE="$(json_get_first "$RESTORED_THREAD_RESPONSE" thread.title title || true)"
if [[ "$RESTORED_THREAD_TITLE" != "Packed host smoke thread" ]]; then
  echo "restored thread title mismatch: expected 'Packed host smoke thread', got '$RESTORED_THREAD_TITLE'" >&2
  echo "response: $RESTORED_THREAD_RESPONSE" >&2
  exit 1
fi

echo "✓ Restored workspace contains expected data"

stop_background_process "$RESTORED_PID"

echo ""
echo "=== Step 13: Verify newly created workspace not in static config ==="

VERIFY_INVENTORY_RESPONSE=$(curl -sS \
  -H "authorization: Bearer $OWNER_TOKEN" \
  "$CONTROL_PLANE_BASE_URL/organizations/$ORG_ID/workspace-inventory")

VERIFY_WS_COUNT=$(python3 -c "
import json, sys
data = json.load(sys.stdin)
workspaces = data.get('workspaces', [])
print(len(workspaces))
" <<<"$VERIFY_INVENTORY_RESPONSE" 2>/dev/null || echo "0")

if [[ "$VERIFY_WS_COUNT" -lt 3 ]]; then
  echo "expected at least 3 workspaces in inventory (original 2 + restored), got $VERIFY_WS_COUNT" >&2
  exit 1
fi

HAS_RESTORED_WS=$(python3 -c "
import json, sys
data = json.load(sys.stdin)
workspaces = data.get('workspaces', [])
for entry in workspaces:
    ws = entry.get('workspace', entry)
    if ws.get('slug') == 'packed-ws-restored':
        print('yes')
        break
" <<<"$VERIFY_INVENTORY_RESPONSE" 2>/dev/null || echo "no")

if [[ "$HAS_RESTORED_WS" != "yes" ]]; then
  echo "restored workspace not found in inventory" >&2
  exit 1
fi

echo "✓ Inventory shows $VERIFY_WS_COUNT workspaces (including newly created restored workspace)"

echo ""
cat >"$TMP_DIR/summary.txt" <<SUMMARY
control_plane_base_url=${CONTROL_PLANE_BASE_URL}
ui_base_url=${UI_BASE_URL}
organization_id=${ORG_ID}
workspace_1_id=${WS1_ID}
workspace_1_base_url=${WS1_BASE_URL}
workspace_1_slug=packed-ws-alpha
workspace_2_id=${WS2_ID}
workspace_2_base_url=${WS2_BASE_URL}
workspace_2_slug=packed-ws-beta
restored_workspace_id=${RESTORED_WS_ID}
restored_workspace_base_url=${RESTORED_BASE_URL}
thread_id=${THREAD_ID}
owner_email=${MOCK_EMAIL}
ui_launch_redirect_to=${UI_REDIRECT_TO}
backup_artifact_count=${BACKUP_ARTIFACT_COUNT}
restore_drill_job_id=${RESTORE_DRILL_JOB_ID}
inventory_workspace_count=${VERIFY_WS_COUNT}
coverage=control-plane,web-ui,shared-ui-login,shared-ui-launch,shared-ui-proxied-read,multi-workspace,account,organization,workspace-provisioning,workspace-launch,session-exchange,workspace-rw,heartbeat,backup,restore,restore-drill,dynamic-workspace-routing
artifacts_dir=${TMP_DIR}
SUMMARY

echo ""
echo "=== Packed-host smoke completed successfully ==="
cat "$TMP_DIR/summary.txt"
