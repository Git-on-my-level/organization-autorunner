#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARTIFACT_DIR="${SMOKE_ARTIFACT_DIR:-$ROOT_DIR/.tmp/e2e-smoke}"
REQUESTED_CORE_PORT="${CORE_PORT:-18080}"
REQUESTED_UI_PORT="${UI_PORT:-4179}"
AUTO_SELECT_PORTS="${AUTO_SELECT_PORTS:-1}"
CORE_HOST="127.0.0.1"
UI_HOST="127.0.0.1"
UI_WORKSPACE_SLUG="${UI_WORKSPACE_SLUG:-${UI_PROJECT_SLUG:-local}}"
BOOTSTRAP_TOKEN="${BOOTSTRAP_TOKEN:-smoke-bootstrap-token}"

mkdir -p "$ARTIFACT_DIR"
TMP_DIR="$(mktemp -d "$ARTIFACT_DIR/run.XXXXXX")"

CORE_LOG="$TMP_DIR/core.log"
UI_LOG="$TMP_DIR/web-ui.log"

HOME_DIR="$TMP_DIR/home"
mkdir -p "$HOME_DIR"
CLI_BIN="$TMP_DIR/oar"
AGENT_NAME="smoke-agent"
USERNAME="smoke.agent"

cleanup() {
  local code=$?
  if [[ -n "${UI_PID:-}" ]] && kill -0 "$UI_PID" >/dev/null 2>&1; then
    kill "$UI_PID" >/dev/null 2>&1 || true
    wait "$UI_PID" >/dev/null 2>&1 || true
  fi
  if [[ -n "${CORE_PID:-}" ]] && kill -0 "$CORE_PID" >/dev/null 2>&1; then
    kill "$CORE_PID" >/dev/null 2>&1 || true
    wait "$CORE_PID" >/dev/null 2>&1 || true
  fi

  if [[ $code -ne 0 ]]; then
    echo "smoke failed; artifacts kept at: $TMP_DIR" >&2
    echo "core log: $CORE_LOG" >&2
    echo "web-ui log: $UI_LOG" >&2
  else
    echo "smoke artifacts: $TMP_DIR"
  fi
}
trap cleanup EXIT INT TERM

require_cmd() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || {
    echo "required command not found: $cmd" >&2
    exit 1
  }
}

pick_free_port() {
  node -e '
const net = require("net");
const host = process.argv[1];
const server = net.createServer();
server.unref();
server.on("error", (err) => {
  console.error(err.message);
  process.exit(1);
});
server.listen(0, host, () => {
  const address = server.address();
  if (!address || typeof address.port !== "number") {
    console.error("failed to resolve a free port");
    process.exit(1);
  }
  process.stdout.write(String(address.port));
  server.close();
});
' "${1}"
}

resolve_port() {
  local requested_port="$1"
  local service_name="$2"

  if ! lsof -ti :"${requested_port}" >/dev/null 2>&1; then
    printf '%s\n' "${requested_port}"
    return 0
  fi

  if [[ "${AUTO_SELECT_PORTS}" != "1" ]]; then
    echo "port ${requested_port} is already in use; aborting to avoid killing unrelated processes" >&2
    lsof -i :"${requested_port}" >&2 || true
    exit 1
  fi

  local selected_port
  selected_port="$(pick_free_port "${CORE_HOST}")"
  echo "port ${requested_port} is already in use; using ${selected_port} for ${service_name}" >&2
  printf '%s\n' "${selected_port}"
}

wait_for_url() {
  local url="$1"
  local attempts="${2:-120}"
  local sleep_seconds="${3:-0.25}"
  shift 3 || true

  for _ in $(seq 1 "$attempts"); do
    if curl -fsS "$@" "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep "$sleep_seconds"
  done
  return 1
}

json_get() {
  local file="$1"
  local path="$2"
  node -e '
const fs = require("fs");
const file = process.argv[1];
const path = process.argv[2].split(".");
const input = fs.readFileSync(file, "utf8").trim();
if (!input) process.exit(2);
const json = JSON.parse(input);
let cur = json;
for (const key of path) {
  if (key === "") continue;
  if (cur === null || cur === undefined) {
    cur = undefined;
    break;
  }
  if (/^\d+$/.test(key)) {
    cur = cur[Number(key)];
  } else {
    cur = cur[key];
  }
}
if (cur === undefined || cur === null) process.exit(3);
if (typeof cur === "object") {
  process.stdout.write(JSON.stringify(cur));
} else {
  process.stdout.write(String(cur));
}
' "$file" "$path"
}

assert_contains() {
  local file="$1"
  local pattern="$2"
  if command -v rg >/dev/null 2>&1; then
    if rg -q "$pattern" "$file"; then
      return 0
    fi
  elif grep -Eq "$pattern" "$file"; then
    return 0
  fi

  echo "assertion failed: expected pattern '$pattern' in $file" >&2
  exit 1
}

run_cli_json() {
  local outfile="$1"
  shift
  HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" "$@" >"$outfile"
}

board_create_attempt() {
  printf '{"board":{"id":"%s","title":"Smoke Board","status":"active","labels":["smoke","board"],"owners":["%s"],"primary_topic_ref":"topic:%s","thread_id":"%s","document_refs":["document:%s"],"pinned_refs":["document:%s"],"provenance":{"sources":["actor_statement:smoke"]}}}\n' \
    "$BOARD_ID" "$USERNAME" "$MAIN_TOPIC_ID" "$BOARD_ID" "$PRIMARY_DOC_ID" "$PRIMARY_DOC_ID" \
    | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" boards create >"$TMP_DIR/board-create.json"
}

ensure_board_created() {
  local max_attempts="${1:-2}"
  local attempt error_code status_code

  for attempt in $(seq 1 "$max_attempts"); do
    if board_create_attempt; then
      return 0
    fi

    # GitHub-hosted runners occasionally surface a transient 500 here even
    # though the preceding authenticated board setup succeeded locally and in
    # repeated stress runs. Probe for the board first, then retry once before
    # failing the full smoke flow.
    if run_cli_json "$TMP_DIR/board-get.json" boards get --board-id "$BOARD_ID"; then
      return 0
    fi

    error_code="$(json_get "$TMP_DIR/board-create.json" 'error.code' || true)"
    status_code="$(json_get "$TMP_DIR/board-create.json" 'error.details.status' || true)"
    if [[ "$attempt" -lt "$max_attempts" && "$error_code" == "internal_error" && "$status_code" == "500" ]]; then
      sleep 0.5
      continue
    fi
    return 1
  done

  return 1
}

require_cmd curl
require_cmd go
require_cmd node
require_cmd pnpm

CORE_PORT="$(resolve_port "${REQUESTED_CORE_PORT}" "oar-core")"
UI_PORT="$(resolve_port "${REQUESTED_UI_PORT}" "web-ui")"
CORE_BASE_URL="http://${CORE_HOST}:${CORE_PORT}"
UI_BASE_URL="http://${UI_HOST}:${UI_PORT}"

# Build CLI binary once for deterministic smoke steps.
(
  cd "$ROOT_DIR/cli"
  go build -o "$CLI_BIN" ./cmd/oar
)

EXPECTED_VERSION="$("${ROOT_DIR}/scripts/read-version.sh")"

# Start core.
(
  cd "$ROOT_DIR/core"
  OAR_BOOTSTRAP_TOKEN="$BOOTSTRAP_TOKEN" go run ./cmd/oar-core \
    --listen-addr "${CORE_HOST}:${CORE_PORT}" \
    --workspace-root "$TMP_DIR/workspace" \
    --schema-path "$ROOT_DIR/contracts/oar-schema.yaml" \
    >"$CORE_LOG" 2>&1
) &
CORE_PID=$!

if ! wait_for_url "$CORE_BASE_URL/readyz" 160 0.15; then
  echo "core did not become healthy" >&2
  cat "$CORE_LOG" >&2 || true
  exit 1
fi

# Start web-ui against core and verify startup handshake route.
(
  cd "$ROOT_DIR"
  OAR_WORKSPACES="[{\"slug\":\"${UI_WORKSPACE_SLUG}\",\"label\":\"${UI_WORKSPACE_SLUG}\",\"coreBaseUrl\":\"${CORE_BASE_URL}\"}]" \
  OAR_DEFAULT_WORKSPACE="$UI_WORKSPACE_SLUG" \
  pnpm -C web-ui exec vite dev --host "$UI_HOST" --port "$UI_PORT" >"$UI_LOG" 2>&1
) &
UI_PID=$!

if ! wait_for_url "$UI_BASE_URL/meta/handshake" 180 0.2 -H "x-oar-workspace-slug: ${UI_WORKSPACE_SLUG}"; then
  echo "web-ui did not become ready on /meta/handshake" >&2
  cat "$UI_LOG" >&2 || true
  exit 1
fi

# Verify UI serves shell too.
curl -fsS -D "$TMP_DIR/ui-shell-headers.txt" -o /dev/null "$UI_BASE_URL/"

# Handshake/version checks.
curl -fsS "$CORE_BASE_URL/meta/handshake" >"$TMP_DIR/core-handshake.json"
curl -fsS "$CORE_BASE_URL/version" >"$TMP_DIR/core-version.json"
assert_contains "$TMP_DIR/core-handshake.json" '"schema_version"'
assert_contains "$TMP_DIR/core-version.json" '"schema_version"'
if [[ "$(json_get "$TMP_DIR/core-handshake.json" 'core_version')" != "$EXPECTED_VERSION" ]]; then
  echo "core_version mismatch in handshake" >&2
  cat "$TMP_DIR/core-handshake.json" >&2 || true
  exit 1
fi
if [[ "$(json_get "$TMP_DIR/core-handshake.json" 'min_cli_version')" != "$EXPECTED_VERSION" ]]; then
  echo "min_cli_version mismatch in handshake" >&2
  cat "$TMP_DIR/core-handshake.json" >&2 || true
  exit 1
fi
if [[ "$(json_get "$TMP_DIR/core-handshake.json" 'recommended_cli_version')" != "$EXPECTED_VERSION" ]]; then
  echo "recommended_cli_version mismatch in handshake" >&2
  cat "$TMP_DIR/core-handshake.json" >&2 || true
  exit 1
fi

UI_VERSION_HEADER="$(
  awk -F': *' '
    BEGIN { IGNORECASE = 1 }
    tolower($1) == "x-oar-ui-version" {
      value = $2
      sub(/\r$/, "", value)
      print value
      exit
    }
  ' "$TMP_DIR/ui-shell-headers.txt"
)"
if [[ "$UI_VERSION_HEADER" != "$EXPECTED_VERSION" ]]; then
  echo "ui version header mismatch" >&2
  cat "$TMP_DIR/ui-shell-headers.txt" >&2 || true
  exit 1
fi

# Register + whoami.
run_cli_json "$TMP_DIR/register.json" auth register --username "$USERNAME" --bootstrap-token "$BOOTSTRAP_TOKEN"
run_cli_json "$TMP_DIR/whoami.json" auth whoami

# Explicit refresh token grant (API fallback) to exercise token lifecycle endpoint.
PROFILE_PATH="$HOME_DIR/.config/oar/profiles/${AGENT_NAME}.json"
REFRESH_TOKEN="$(node -e 'const fs=require("fs"); const p=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(String(p.refresh_token||""));' "$PROFILE_PATH")"
if [[ -z "$REFRESH_TOKEN" ]]; then
  echo "missing refresh token in profile: $PROFILE_PATH" >&2
  exit 1
fi
printf '{"grant_type":"refresh_token","refresh_token":"%s"}\n' "$REFRESH_TOKEN" | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" api call --method POST --path /auth/token >"$TMP_DIR/token-refresh-explicit.json"
assert_contains "$TMP_DIR/token-refresh-explicit.json" '"access_token"'

# Force automatic refresh path by expiring local access token.
node -e '
const fs = require("fs");
const file = process.argv[1];
const profile = JSON.parse(fs.readFileSync(file, "utf8"));
profile.access_token_expires_at = "2000-01-01T00:00:00Z";
fs.writeFileSync(file, JSON.stringify(profile, null, 2) + "\n");
' "$PROFILE_PATH"

run_cli_json "$TMP_DIR/token-status-before.json" auth token-status
run_cli_json "$TMP_DIR/topics-list-before.json" topics list
run_cli_json "$TMP_DIR/token-status-after.json" auth token-status

NEEDS_REFRESH_BEFORE="$(json_get "$TMP_DIR/token-status-before.json" 'data.needs_refresh' || true)"
NEEDS_REFRESH_AFTER="$(json_get "$TMP_DIR/token-status-after.json" 'data.needs_refresh' || true)"
if [[ "$NEEDS_REFRESH_BEFORE" != "true" ]]; then
  echo "expected needs_refresh=true before auto-refresh, got: ${NEEDS_REFRESH_BEFORE:-<missing>}" >&2
  exit 1
fi
if [[ "$NEEDS_REFRESH_AFTER" != "false" ]]; then
  echo "expected needs_refresh=false after auto-refresh, got: ${NEEDS_REFRESH_AFTER:-<missing>}" >&2
  exit 1
fi

# Typed command flow: topic -> board -> cards -> packets.
printf '{"topic":{"id":"topic-smoke-main","type":"initiative","status":"active","title":"Smoke coordination topic","summary":"Smoke workflow in progress","owner_refs":[],"board_refs":[],"document_refs":[],"related_refs":["topic:topic-smoke-main"],"provenance":{"sources":["actor_statement:smoke"]}}}\n' \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" topics create >"$TMP_DIR/topic-create.json"
MAIN_TOPIC_ID="$(json_get "$TMP_DIR/topic-create.json" 'data.topic.id' || true)"
if [[ -z "$MAIN_TOPIC_ID" ]]; then
  MAIN_TOPIC_ID="$(json_get "$TMP_DIR/topic-create.json" 'data.body.topic.id' || true)"
fi
MAIN_TOPIC_THREAD_ID="$(json_get "$TMP_DIR/topic-create.json" 'data.topic.thread_id' || true)"
if [[ -z "$MAIN_TOPIC_THREAD_ID" ]]; then
  MAIN_TOPIC_THREAD_ID="$(json_get "$TMP_DIR/topic-create.json" 'data.body.topic.thread_id' || true)"
fi
if [[ -z "$MAIN_TOPIC_ID" || -z "$MAIN_TOPIC_THREAD_ID" ]]; then
  echo "failed to parse main topic id or backing thread id" >&2
  cat "$TMP_DIR/topic-create.json" >&2 || true
  exit 1
fi

printf '{"patch":{"summary":"smoke updated"}}\n' \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" topics patch --topic-id "$MAIN_TOPIC_ID" >"$TMP_DIR/topic-update.json"

RECEIPT_ID="artifact-receipt-smoke"
REVIEW_ID="artifact-review-smoke"
THREAD_ID="$MAIN_TOPIC_THREAD_ID"

# Board smoke: create a board, add/reorder/move/archive cards, and verify the
# canonical workspace through both core and the UI proxy.
printf '{"topic":{"id":"topic-smoke-board-a","type":"initiative","status":"active","title":"Smoke board card A","summary":"board card A","owner_refs":[],"board_refs":[],"document_refs":[],"related_refs":["topic:topic-smoke-board-a"],"provenance":{"sources":["actor_statement:smoke"]}}}\n' \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" topics create >"$TMP_DIR/board-topic-a-create.json"
BOARD_TOPIC_A_ID="$(json_get "$TMP_DIR/board-topic-a-create.json" 'data.topic.id' || true)"
if [[ -z "$BOARD_TOPIC_A_ID" ]]; then
  BOARD_TOPIC_A_ID="$(json_get "$TMP_DIR/board-topic-a-create.json" 'data.body.topic.id' || true)"
fi
BOARD_THREAD_A_ID="$(json_get "$TMP_DIR/board-topic-a-create.json" 'data.topic.thread_id' || true)"
if [[ -z "$BOARD_THREAD_A_ID" ]]; then
  BOARD_THREAD_A_ID="$(json_get "$TMP_DIR/board-topic-a-create.json" 'data.body.topic.thread_id' || true)"
fi
if [[ -z "$BOARD_THREAD_A_ID" ]]; then
  echo "failed to parse board topic A id or backing thread id" >&2
  cat "$TMP_DIR/board-topic-a-create.json" >&2 || true
  exit 1
fi
if [[ -z "$BOARD_TOPIC_A_ID" ]]; then
  echo "failed to parse board topic A id" >&2
  cat "$TMP_DIR/board-topic-a-create.json" >&2 || true
  exit 1
fi

printf '{"topic":{"id":"topic-smoke-board-b","type":"initiative","status":"active","title":"Smoke board card B","summary":"board card B","owner_refs":[],"board_refs":[],"document_refs":[],"related_refs":["topic:topic-smoke-board-b"],"provenance":{"sources":["actor_statement:smoke"]}}}\n' \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" topics create >"$TMP_DIR/board-topic-b-create.json"
BOARD_TOPIC_B_ID="$(json_get "$TMP_DIR/board-topic-b-create.json" 'data.topic.id' || true)"
if [[ -z "$BOARD_TOPIC_B_ID" ]]; then
  BOARD_TOPIC_B_ID="$(json_get "$TMP_DIR/board-topic-b-create.json" 'data.body.topic.id' || true)"
fi
BOARD_THREAD_B_ID="$(json_get "$TMP_DIR/board-topic-b-create.json" 'data.topic.thread_id' || true)"
if [[ -z "$BOARD_THREAD_B_ID" ]]; then
  BOARD_THREAD_B_ID="$(json_get "$TMP_DIR/board-topic-b-create.json" 'data.body.topic.thread_id' || true)"
fi
if [[ -z "$BOARD_THREAD_B_ID" ]]; then
  echo "failed to parse board topic B id or backing thread id" >&2
  cat "$TMP_DIR/board-topic-b-create.json" >&2 || true
  exit 1
fi

PRIMARY_DOC_ID="doc-smoke-board-primary"
CARD_DOC_ID="doc-smoke-board-card"

printf '{"document":{"id":"%s","title":"Smoke Board Primary Doc","status":"active","labels":["smoke","board"]},"refs":["topic:%s","thread:%s"],"content":"Primary board document","content_type":"text"}\n' "$PRIMARY_DOC_ID" "$MAIN_TOPIC_ID" "$THREAD_ID" \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" docs create >"$TMP_DIR/board-primary-doc-create.json"

printf '{"document":{"id":"%s","title":"Smoke Board Card Doc","status":"active","labels":["smoke","board"]},"refs":["topic:%s","thread:%s"],"content":"Pinned card document","content_type":"text"}\n' "$CARD_DOC_ID" "$BOARD_TOPIC_A_ID" "$BOARD_THREAD_A_ID" \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" docs create >"$TMP_DIR/board-card-doc-create.json"

BOARD_ID="board-smoke"
if ! ensure_board_created 2; then
  echo "failed to create board after retry" >&2
  cat "$TMP_DIR/board-create.json" >&2 || true
  exit 1
fi

BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-create.json" 'data.board.updated_at' || true)"
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-create.json" 'data.body.board.updated_at' || true)"
fi
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  run_cli_json "$TMP_DIR/board-get.json" boards get --board-id "$BOARD_ID"
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-get.json" 'data.board.updated_at' || true)"
fi
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-get.json" 'data.body.board.updated_at' || true)"
fi
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  echo "failed to parse board updated_at after create" >&2
  cat "$TMP_DIR/board-create.json" >&2 || true
  cat "$TMP_DIR/board-get.json" >&2 || true
  exit 1
fi

run_cli_json "$TMP_DIR/board-get.json" boards get --board-id "$BOARD_ID"

printf '{"card":{"title":"Smoke board card A","summary":"smoke card A","column_key":"backlog","topic_ref":"topic:%s","document_ref":"document:%s","assignee_refs":[],"risk":"low","resolution_refs":[],"related_refs":["topic:%s"],"provenance":{"sources":["actor_statement:smoke"]}}}\n' \
  "$BOARD_TOPIC_A_ID" "$CARD_DOC_ID" "$BOARD_TOPIC_A_ID" \
  | run_cli_json "$TMP_DIR/board-card-a-add.json" boards cards create --board-id "$BOARD_ID"
BOARD_CARD_A_ID="$(json_get "$TMP_DIR/board-card-a-add.json" 'data.card.id' || true)"
if [[ -z "$BOARD_CARD_A_ID" ]]; then
  BOARD_CARD_A_ID="$(json_get "$TMP_DIR/board-card-a-add.json" 'data.body.card.id' || true)"
fi
if [[ -z "$BOARD_CARD_A_ID" ]]; then
  echo "failed to parse board card A id" >&2
  cat "$TMP_DIR/board-card-a-add.json" >&2 || true
  exit 1
fi
BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-card-a-add.json" 'data.board.updated_at' || true)"
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-card-a-add.json" 'data.body.board.updated_at' || true)"
fi
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  run_cli_json "$TMP_DIR/board-refresh-after-card-a.json" boards get --board-id "$BOARD_ID"
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-refresh-after-card-a.json" 'data.board.updated_at' || true)"
  if [[ -z "$BOARD_UPDATED_AT" ]]; then
    BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-refresh-after-card-a.json" 'data.body.board.updated_at' || true)"
  fi
fi
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  echo "failed to parse board updated_at after card A create" >&2
  exit 1
fi

printf '{"artifact":{"id":"%s","refs":["card:%s"],"summary":"Smoke receipt"},"packet":{"receipt_id":"%s","subject_ref":"card:%s","outputs":["card:%s"],"verification_evidence":["artifact:%s"],"changes_summary":"smoke complete","known_gaps":[]}}\n' "$RECEIPT_ID" "$BOARD_CARD_A_ID" "$RECEIPT_ID" "$BOARD_CARD_A_ID" "$BOARD_CARD_A_ID" "$RECEIPT_ID" \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" receipts create >"$TMP_DIR/receipt-create.json"

printf '{"artifact":{"id":"%s","refs":["card:%s","artifact:%s"],"summary":"Smoke review"},"packet":{"review_id":"%s","subject_ref":"card:%s","receipt_ref":"artifact:%s","outcome":"accept","notes":"accepted","evidence_refs":["artifact:%s"]}}\n' "$REVIEW_ID" "$BOARD_CARD_A_ID" "$RECEIPT_ID" "$REVIEW_ID" "$BOARD_CARD_A_ID" "$RECEIPT_ID" "$RECEIPT_ID" \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" reviews create >"$TMP_DIR/review-create.json"

printf '{"card":{"title":"Smoke board card B","summary":"smoke card B","column_key":"backlog","after_card_id":"%s","topic_ref":"topic:%s","assignee_refs":[],"risk":"low","resolution_refs":[],"related_refs":["topic:%s"],"provenance":{"sources":["actor_statement:smoke"]}}}\n' \
  "$BOARD_CARD_A_ID" "$BOARD_TOPIC_B_ID" "$BOARD_TOPIC_B_ID" \
  | run_cli_json "$TMP_DIR/board-card-b-add.json" boards cards create --board-id "$BOARD_ID"
BOARD_CARD_B_ID="$(json_get "$TMP_DIR/board-card-b-add.json" 'data.card.id' || true)"
if [[ -z "$BOARD_CARD_B_ID" ]]; then
  BOARD_CARD_B_ID="$(json_get "$TMP_DIR/board-card-b-add.json" 'data.body.card.id' || true)"
fi
if [[ -z "$BOARD_CARD_B_ID" ]]; then
  echo "failed to parse board card B id" >&2
  cat "$TMP_DIR/board-card-b-add.json" >&2 || true
  exit 1
fi
BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-card-b-add.json" 'data.board.updated_at' || true)"
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-card-b-add.json" 'data.body.board.updated_at' || true)"
fi
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  run_cli_json "$TMP_DIR/board-refresh-after-card-b.json" boards get --board-id "$BOARD_ID"
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-refresh-after-card-b.json" 'data.board.updated_at' || true)"
  if [[ -z "$BOARD_UPDATED_AT" ]]; then
    BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-refresh-after-card-b.json" 'data.body.board.updated_at' || true)"
  fi
fi
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  echo "failed to parse board updated_at after card B create" >&2
  exit 1
fi

printf '{"column_key":"review","if_board_updated_at":"%s"}\n' "$BOARD_UPDATED_AT" \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" cards move --card-id "$BOARD_CARD_B_ID" >"$TMP_DIR/board-card-b-move.json"
BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-card-b-move.json" 'data.board.updated_at' || true)"
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-card-b-move.json" 'data.body.board.updated_at' || true)"
fi

ACCESS_TOKEN="$(node -e 'const fs=require("fs"); const p=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(String(p.access_token||""));' "$PROFILE_PATH")"
if [[ -z "$ACCESS_TOKEN" ]]; then
  echo "missing access token in profile: $PROFILE_PATH" >&2
  exit 1
fi

run_cli_json "$TMP_DIR/board-workspace.json" boards workspace --board-id "$BOARD_ID"
assert_contains "$TMP_DIR/board-workspace.json" "\"board_id\"[[:space:]]*:[[:space:]]*\"$BOARD_ID\""
# Card B is anchored on topic B; backing thread ids are per-card (not the topic's thread_id).
assert_contains "$TMP_DIR/board-workspace.json" '"topic:topic-smoke-board-b"'
assert_contains "$TMP_DIR/board-workspace.json" "\"column_key\"[[:space:]]*:[[:space:]]*\"review\""

curl -fsS -H "x-oar-workspace-slug: ${UI_WORKSPACE_SLUG}" -H "Authorization: Bearer $ACCESS_TOKEN" "$UI_BASE_URL/boards/${BOARD_ID}/workspace" >"$TMP_DIR/ui-board-workspace.json"
assert_contains "$TMP_DIR/ui-board-workspace.json" "\"board_id\"[[:space:]]*:[[:space:]]*\"$BOARD_ID\""

# Refresh board concurrency token (cards.move may not echo `board` in the CLI envelope).
run_cli_json "$TMP_DIR/board-before-terminal.json" boards get --board-id "$BOARD_ID"
BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-before-terminal.json" 'data.board.updated_at' || true)"
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-before-terminal.json" 'data.body.board.updated_at' || true)"
fi
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  echo "failed to parse board updated_at before terminal card move" >&2
  cat "$TMP_DIR/board-before-terminal.json" >&2 || true
  exit 1
fi

run_cli_json "$TMP_DIR/card-a-backing-thread.json" cards get --card-id "$BOARD_CARD_A_ID"
CARD_A_THREAD_ID="$(json_get "$TMP_DIR/card-a-backing-thread.json" 'data.card.thread_id' || true)"
if [[ -z "$CARD_A_THREAD_ID" ]]; then
  CARD_A_THREAD_ID="$(json_get "$TMP_DIR/card-a-backing-thread.json" 'data.body.card.thread_id' || true)"
fi
if [[ -z "$CARD_A_THREAD_ID" ]]; then
  echo "failed to parse backing thread id for card A" >&2
  cat "$TMP_DIR/card-a-backing-thread.json" >&2 || true
  exit 1
fi

printf '{"event":{"type":"message_posted","thread_id":"%s","summary":"smoke cancel rationale","refs":["thread:%s","card:%s"],"payload":{"body":"scope withdrawn"},"provenance":{"sources":["actor_statement:smoke"]}}}\n' \
  "$CARD_A_THREAD_ID" "$CARD_A_THREAD_ID" "$BOARD_CARD_A_ID" \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" events create >"$TMP_DIR/cancel-rationale-event.json"
CANCEL_EVENT_ID="$(json_get "$TMP_DIR/cancel-rationale-event.json" 'data.event.id' || true)"
if [[ -z "$CANCEL_EVENT_ID" ]]; then
  CANCEL_EVENT_ID="$(json_get "$TMP_DIR/cancel-rationale-event.json" 'data.body.event.id' || true)"
fi
if [[ -z "$CANCEL_EVENT_ID" ]]; then
  echo "failed to parse event id for cancel rationale" >&2
  cat "$TMP_DIR/cancel-rationale-event.json" >&2 || true
  exit 1
fi

# Spec §3.5 / §3.6: terminal resolution is explicit (canceled + resolution_refs), distinct from board flow alone.
printf '{"column_key":"done","resolution":"canceled","resolution_refs":["event:%s"],"if_board_updated_at":"%s"}\n' "$CANCEL_EVENT_ID" "$BOARD_UPDATED_AT" \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" cards move --card-id "$BOARD_CARD_A_ID" >"$TMP_DIR/board-card-a-cancel.json"

run_cli_json "$TMP_DIR/board-after-terminal.json" boards get --board-id "$BOARD_ID"
BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-after-terminal.json" 'data.board.updated_at' || true)"
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  BOARD_UPDATED_AT="$(json_get "$TMP_DIR/board-after-terminal.json" 'data.body.board.updated_at' || true)"
fi
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  echo "failed to parse board updated_at after canceled resolution move" >&2
  cat "$TMP_DIR/board-after-terminal.json" >&2 || true
  exit 1
fi

run_cli_json "$TMP_DIR/card-a-after-cancel.json" cards get --card-id "$BOARD_CARD_A_ID"
assert_contains "$TMP_DIR/card-a-after-cancel.json" '"resolution"[[:space:]]*:[[:space:]]*"canceled"'
node -e 'const fs=require("fs"); const data=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); const card=data?.data?.card ?? data?.data?.body?.card; const refs=Array.isArray(card?.resolution_refs) ? card.resolution_refs : []; const expected=`event:${process.argv[2]}`; if (!refs.includes(expected)) process.exit(1);' "$TMP_DIR/card-a-after-cancel.json" "$CANCEL_EVENT_ID" || {
  echo "missing expected resolution ref event:${CANCEL_EVENT_ID}" >&2
  cat "$TMP_DIR/card-a-after-cancel.json" >&2 || true
  exit 1
}

# Trash lane (operational lifecycle, spec §3.6) — topics support trash; default topic list hides trashed rows.
printf '{"topic":{"id":"topic-smoke-trash","type":"other","status":"active","title":"Smoke trashed topic","summary":"Disposed after smoke","owner_refs":[],"board_refs":[],"document_refs":[],"related_refs":["topic:topic-smoke-trash"],"provenance":{"sources":["actor_statement:smoke"]}}}\n' \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" topics create >"$TMP_DIR/trash-topic-create.json"
printf '{"reason":"e2e-smoke trash lane assertion"}\n' \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" topics trash --topic-id topic-smoke-trash >"$TMP_DIR/topic-trash.json"
curl -fsS -H "Authorization: Bearer $ACCESS_TOKEN" "${CORE_BASE_URL}/topics?trashed_only=true" >"$TMP_DIR/topics-trashed-only.json"
assert_contains "$TMP_DIR/topics-trashed-only.json" 'topic-smoke-trash'

# Card trash lane (archive / archived_only inventory).
printf '{"if_board_updated_at":"%s"}\n' "$BOARD_UPDATED_AT" \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" cards archive --card-id "$BOARD_CARD_B_ID" >"$TMP_DIR/board-card-b-archive.json"
curl -fsS -H "Authorization: Bearer $ACCESS_TOKEN" "${CORE_BASE_URL}/cards?archived_only=true" >"$TMP_DIR/cards-archived-only.json"
assert_contains "$TMP_DIR/cards-archived-only.json" "\"${BOARD_CARD_B_ID}\""

printf '{"event":{"type":"message_posted","thread_id":"%s","summary":"smoke stream event","refs":["thread:%s"],"payload":{"body":"hello"},"provenance":{"sources":["actor_statement:smoke"]}}}\n' "$THREAD_ID" "$THREAD_ID" \
  | HOME="$HOME_DIR" "$CLI_BIN" --json --base-url "$CORE_BASE_URL" --agent "$AGENT_NAME" events create >"$TMP_DIR/event-create.json"

# Basic UI compatibility check after typed flow.
curl -fsS -H "x-oar-workspace-slug: ${UI_WORKSPACE_SLUG}" "$UI_BASE_URL/meta/handshake" >"$TMP_DIR/ui-handshake.json"
assert_contains "$TMP_DIR/ui-handshake.json" '"schema_version"'

cat >"$TMP_DIR/summary.txt" <<SUMMARY
core_base_url=${CORE_BASE_URL}
ui_base_url=${UI_BASE_URL}
thread_id=${THREAD_ID}
board_id=${BOARD_ID}
agent=${AGENT_NAME}
profile_path=${PROFILE_PATH}
artifacts_dir=${TMP_DIR}
SUMMARY

echo "e2e smoke completed successfully"
cat "$TMP_DIR/summary.txt"
