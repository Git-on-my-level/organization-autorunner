{
  "name": "harness-docs-lifecycle-conflict-workflow",
  "base_url": "http://127.0.0.1:8000",
  "agents": [
    {
      "name": "coordinator",
      "username_prefix": "coordinator",
      "deterministic_steps": [
        {
          "name": "create thread",
          "args": ["threads", "create"],
          "stdin": {
            "thread": {
              "title": "Harness Docs Lifecycle {{run.id}}",
              "type": "process",
              "status": "active",
              "priority": "p2",
              "tags": ["harness", "docs", "review"],
              "cadence": "reactive",
              "current_summary": "Coordinator started docs lifecycle run {{run.id}}.",
              "next_actions": ["Worker updates draft document", "Reviewer resolves concurrency-safe review"],
              "key_artifacts": [],
              "provenance": {
                "sources": ["inferred"]
              }
            }
          },
          "capture": {
            "thread_id": "data.body.thread.thread_id"
          }
        },
        {
          "name": "create baseline document",
          "args": ["docs", "create"],
          "stdin": {
            "document": {
              "id": "policy-{{run.id}}"
            },
            "refs": ["thread:{{coordinator.thread_id}}"],
            "content": "Baseline run {{run.id}} policy draft (v1).",
            "content_type": "text",
            "provenance": {
              "sources": ["inferred"]
            }
          },
          "capture": {
            "document_id": "data.body.document.id",
            "initial_revision_id": "data.body.revision.revision_id"
          }
        },
        {
          "name": "post initial decision-needed event",
          "args": ["events", "create"],
          "stdin": {
            "event": {
              "type": "decision_needed",
              "thread_id": "{{coordinator.thread_id}}",
              "refs": ["thread:{{coordinator.thread_id}}", "document:{{coordinator.document_id}}"],
              "summary": "Coordinator requested draft + review for run {{run.id}}",
              "payload": {
                "run_id": "{{run.id}}",
                "document_id": "{{coordinator.document_id}}",
                "initial_revision_id": "{{coordinator.initial_revision_id}}"
              },
              "provenance": {
                "sources": ["inferred"]
              }
            }
          },
          "capture": {
            "decision_event_id": "data.body.event.id"
          }
        },
        {
          "name": "annotate thread lifecycle status",
          "args": ["threads", "patch", "--thread-id", "{{coordinator.thread_id}}"],
          "stdin": {
            "patch": {
              "current_summary": "Worker owns draft {{coordinator.document_id}} revisioning for run {{run.id}}.",
              "next_actions": [
                "Worker drafts updated revision",
                "Reviewer validates and records review outcome"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "worker",
      "username_prefix": "worker",
      "deterministic_steps": [
        {
          "name": "read coordination context",
          "args": ["threads", "context", "--thread-id", "{{coordinator.thread_id}}"],
          "stdin": {}
        },
        {
          "name": "read coordinator decision event",
          "args": ["events", "get", "--event-id", "{{coordinator.decision_event_id}}"]
        },
        {
          "name": "acknowledge claim",
          "args": ["events", "create"],
          "stdin": {
            "event": {
              "type": "actor_statement",
              "thread_id": "{{coordinator.thread_id}}",
              "refs": ["thread:{{coordinator.thread_id}}", "event:{{coordinator.decision_event_id}}"],
              "summary": "Worker accepted run {{run.id}} draft task",
              "payload": {
                "run_id": "{{run.id}}",
                "document_id": "{{coordinator.document_id}}"
              },
              "provenance": {
                "sources": ["inferred"]
              }
            }
          },
          "capture": {
            "ack_event_id": "data.body.event.id"
          }
        },
        {
          "name": "publish worker revision (based on baseline)",
          "args": ["docs", "update", "--document-id", "{{coordinator.document_id}}"],
          "stdin": {
            "if_base_revision": "{{coordinator.initial_revision_id}}",
            "content": "Worker-produced revision for run {{run.id}} (v2).",
            "content_type": "text",
            "refs": ["thread:{{coordinator.thread_id}}", "event:{{coordinator.decision_event_id}}"]
          },
          "capture": {
            "updated_revision_id": "data.body.revision.revision_id"
          }
        },
        {
          "name": "announce draft handoff",
          "args": ["events", "create"],
          "stdin": {
            "event": {
              "type": "message_posted",
              "thread_id": "{{coordinator.thread_id}}",
              "refs": ["thread:{{coordinator.thread_id}}", "document:{{coordinator.document_id}}", "event:{{worker.ack_event_id}}"],
              "summary": "Worker posted draft revision for run {{run.id}}",
              "payload": {
                "run_id": "{{run.id}}",
                "document_id": "{{coordinator.document_id}}",
                "revision_id": "{{worker.updated_revision_id}}"
              },
              "provenance": {
                "sources": ["inferred"]
              }
            }
          },
          "capture": {
            "completion_event_id": "data.body.event.id"
          }
        }
      ]
    },
    {
      "name": "reviewer",
      "username_prefix": "reviewer",
      "deterministic_steps": [
        {
          "name": "read thread context",
          "args": ["threads", "context", "--thread-id", "{{coordinator.thread_id}}"]
        },
        {
          "name": "read latest document revision pre-conflict",
          "args": ["docs", "get", "--document-id", "{{coordinator.document_id}}"],
          "capture": {
            "pre_conflict_head_revision_id": "data.body.revision.revision_id"
          }
        },
        {
          "name": "attempt stale overwrite (expected conflict)",
          "args": ["docs", "update", "--document-id", "{{coordinator.document_id}}"],
          "stdin": {
            "if_base_revision": "{{coordinator.initial_revision_id}}",
            "content": "Reviewer stale overwrite attempt for run {{run.id}}.",
            "content_type": "text",
            "refs": ["thread:{{coordinator.thread_id}}", "event:{{worker.completion_event_id}}"]
          },
          "expect_error": {
            "code": "conflict",
            "status": 409,
            "message_contains": "document has been updated"
          }
        },
        {
          "name": "re-read revision after conflict window",
          "args": ["docs", "get", "--document-id", "{{coordinator.document_id}}"],
          "capture": {
            "post_conflict_head_revision_id": "data.body.revision.revision_id"
          }
        },
        {
          "name": "record review outcome",
          "args": ["events", "create"],
          "stdin": {
            "event": {
              "type": "actor_statement",
              "thread_id": "{{coordinator.thread_id}}",
              "refs": ["thread:{{coordinator.thread_id}}", "document:{{coordinator.document_id}}", "event:{{worker.completion_event_id}}"],
              "summary": "Reviewer completed review for run {{run.id}} (conflict-safe check passed).",
              "payload": {
                "run_id": "{{run.id}}",
                "document_id": "{{coordinator.document_id}}",
                "observed_revision_id": "{{reviewer.post_conflict_head_revision_id}}"
              },
              "provenance": {
                "sources": ["inferred"]
              }
            }
          },
          "capture": {
            "review_event_id": "data.body.event.id"
          }
        },
        {
          "name": "close thread action list after review",
          "args": ["threads", "patch", "--thread-id", "{{coordinator.thread_id}}"],
          "stdin": {
            "patch": {
              "current_summary": "Reviewer reviewed run {{run.id}} and recorded outcome event.",
              "next_actions": ["Coordinator closes thread"]
            }
          }
        }
      ]
    }
  ],
  "assertions": [
    {
      "name": "coordinator can read the created thread",
      "agent": "coordinator",
      "args": ["threads", "get", "--thread-id", "{{coordinator.thread_id}}"],
      "contains": ["Harness Docs Lifecycle", "{{run.id}}"]
    },
    {
      "name": "worker completion event is retrievable",
      "agent": "coordinator",
      "args": ["events", "get", "--event-id", "{{worker.completion_event_id}}"],
      "contains": ["message_posted", "Worker posted draft revision", "{{run.id}}"]
    },
    {
      "name": "coordinator sees worker revision as current head after reviewer conflict attempt",
      "agent": "coordinator",
      "args": ["docs", "get", "--document-id", "{{coordinator.document_id}}"],
      "json_paths": {
        "data.body.revision.revision_id": "{{worker.updated_revision_id}}"
      }
    },
    {
      "name": "stale overwrite did not advance revision head",
      "agent": "reviewer",
      "args": ["docs", "get", "--document-id", "{{coordinator.document_id}}"],
      "json_paths": {
        "data.body.revision.revision_id": "{{worker.updated_revision_id}}"
      }
    },
    {
      "name": "document history includes both baseline and worker revision",
      "agent": "reviewer",
      "args": ["docs", "history", "--document-id", "{{coordinator.document_id}}"],
      "contains": [
        "{{coordinator.initial_revision_id}}",
        "{{worker.updated_revision_id}}"
      ]
    },
    {
      "name": "review event recorded and linked",
      "agent": "coordinator",
      "args": ["events", "get", "--event-id", "{{reviewer.review_event_id}}"],
      "contains": ["actor_statement", "conflict-safe", "{{run.id}}"]
    }
  ]
}
