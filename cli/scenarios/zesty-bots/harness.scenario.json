{
  "name": "zesty-bots-harness-smoke",
  "base_url": "http://127.0.0.1:8000",
  "agents": [
    {
      "name": "coordinator",
      "username_prefix": "coordinator",
      "llm": {
        "objective": "Coordinate initial triage and create an explicit decision-needed event on the active thread.",
        "profile_path": "cli/scenarios/profiles/coordinator.md",
        "max_turns": 8
      },
      "deterministic_steps": [
        {
          "name": "create thread",
          "args": ["threads", "create"],
          "stdin": {
            "thread": {
              "title": "Harness Incident {{run.id}}",
              "type": "incident",
              "status": "active",
              "priority": "p2",
              "tags": ["harness", "zesty-bots"],
              "cadence": "reactive",
              "current_summary": "Thread created by scenario harness for multi-agent integration validation.",
              "next_actions": ["Record decision-needed event", "Worker acknowledges state"],
              "key_artifacts": [],
              "provenance": {
                "sources": ["inferred"]
              }
            }
          },
          "capture": {
            "thread_id": "data.body.thread.thread_id"
          }
        },
        {
          "name": "create decision-needed event",
          "args": ["events", "create"],
          "stdin": {
            "event": {
              "type": "decision_needed",
              "thread_id": "{{coordinator.thread_id}}",
              "refs": ["thread:{{coordinator.thread_id}}"],
              "summary": "Need worker acknowledgement for harness run {{run.id}}",
              "payload": {
                "run_id": "{{run.id}}",
                "source": "scenario_harness"
              },
              "provenance": {
                "sources": ["inferred"]
              }
            }
          }
        }
      ]
    },
    {
      "name": "worker",
      "username_prefix": "worker",
      "llm": {
        "objective": "Read the coordinator thread and post a worker acknowledgement event tied to the same thread.",
        "profile_path": "cli/scenarios/profiles/worker.md",
        "max_turns": 8
      },
      "deterministic_steps": [
        {
          "name": "read created thread",
          "args": ["threads", "get", "--thread-id", "{{coordinator.thread_id}}"]
        },
        {
          "name": "post worker acknowledgement",
          "args": ["events", "create"],
          "stdin": {
            "event": {
              "type": "actor_statement",
              "thread_id": "{{coordinator.thread_id}}",
              "refs": ["thread:{{coordinator.thread_id}}"],
              "summary": "Worker acknowledged harness thread {{coordinator.thread_id}}",
              "payload": {
                "run_id": "{{run.id}}",
                "source": "scenario_harness"
              },
              "provenance": {
                "sources": ["inferred"]
              }
            }
          },
          "capture": {
            "worker_event_id": "data.body.event.id"
          }
        }
      ]
    }
  ],
  "assertions": [
    {
      "name": "worker can read coordinator thread",
      "agent": "worker",
      "args": ["threads", "get", "--thread-id", "{{coordinator.thread_id}}"],
      "contains": ["Harness Incident", "{{run.id}}"]
    },
    {
      "name": "coordinator sees worker acknowledgement event",
      "agent": "coordinator",
      "args": ["events", "get", "--event-id", "{{worker.worker_event_id}}"],
      "contains": ["Worker acknowledged harness thread"]
    },
    {
      "name": "thread id consistency",
      "agent": "coordinator",
      "args": ["threads", "get", "--thread-id", "{{coordinator.thread_id}}"],
      "json_paths": {
        "data.body.thread.thread_id": "{{coordinator.thread_id}}"
      }
    }
  ]
}
