#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

PORT="${PORT:-18081}"
LISTEN_ADDR="127.0.0.1:${PORT}"
BASE_URL="http://${LISTEN_ADDR}"

TMP_DIR="$(mktemp -d)"
WORKSPACE_ROOT="$TMP_DIR/workspace"
SERVER_LOG="$TMP_DIR/server.log"

ACTOR_ID="smoke-actor"
MAIN_TOPIC_ID="topic-smoke-main"
CARD_A_TOPIC_ID="topic-smoke-card-a"
CARD_B_TOPIC_ID="topic-smoke-card-b"
PRIMARY_DOC_ID="doc-smoke-primary"
CARD_DOC_ID="doc-smoke-card"
BOARD_ID="board-smoke"
RECEIPT_ID="artifact-smoke-receipt"
REVIEW_ID="artifact-smoke-review"

cleanup() {
  if [[ -n "${SERVER_PID:-}" ]] && kill -0 "$SERVER_PID" 2>/dev/null; then
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
  fi
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT

post_json() {
  local path="$1"
  local body="$2"
  curl -fsS -H "Content-Type: application/json" -d "$body" "${BASE_URL}${path}"
}

get_json() {
  local path="$1"
  curl -fsS "${BASE_URL}${path}"
}

json_get() {
  local file="$1"
  local path="$2"
  node -e '
const fs = require("fs");
const file = process.argv[1];
const path = process.argv[2].split(".");
const input = fs.readFileSync(file, "utf8").trim();
if (!input) process.exit(2);
const json = JSON.parse(input);
let cur = json;
for (const key of path) {
  if (key === "") continue;
  if (cur === null || cur === undefined) {
    cur = undefined;
    break;
  }
  if (/^\d+$/.test(key)) {
    cur = cur[Number(key)];
  } else {
    cur = cur[key];
  }
}
if (cur === undefined || cur === null) process.exit(3);
if (typeof cur === "object") {
  process.stdout.write(JSON.stringify(cur));
} else {
  process.stdout.write(String(cur));
}
' "$file" "$path"
}

extract_first_field() {
  local json="$1"
  local field="$2"
  printf '%s' "$json" \
    | rg -o "\"${field}\":\"[^\"]+\"" \
    | head -n 1 \
    | sed -E "s/\"${field}\":\"([^\"]+)\"/\\1/"
}

wait_for_ready() {
  for _ in $(seq 1 80); do
    if curl -fsS "${BASE_URL}/readyz" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

echo "starting oar-core on ${BASE_URL}"
OAR_ENABLE_DEV_ACTOR_MODE=1 \
OAR_ALLOW_UNAUTHENTICATED_WRITES=1 \
go run ./cmd/oar-core \
  --listen-addr "$LISTEN_ADDR" \
  --workspace-root "$WORKSPACE_ROOT" \
  --schema-path "$ROOT_DIR/../contracts/oar-schema.yaml" \
  >"$SERVER_LOG" 2>&1 &
SERVER_PID=$!

if ! wait_for_ready; then
  echo "server did not become healthy; log follows:" >&2
  cat "$SERVER_LOG" >&2
  exit 1
fi

VERSION_JSON="$(get_json "/version")"
echo "version: ${VERSION_JSON}"

echo "registering actor"
post_json "/actors" "$(cat <<JSON
{
  "actor": {
    "id": "${ACTOR_ID}",
    "display_name": "Smoke Actor",
    "tags": ["smoke"],
    "created_at": "2026-03-04T10:00:00Z"
  }
}
JSON
)" >/dev/null

echo "creating topics"
MAIN_TOPIC_RESP="$(post_json "/topics" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "topic": {
    "id": "${MAIN_TOPIC_ID}",
    "type": "initiative",
    "status": "active",
    "title": "Smoke coordination topic",
    "summary": "Smoke workflow in progress",
    "owner_refs": ["actor:${ACTOR_ID}"],
    "board_refs": [],
    "document_refs": [],
    "related_refs": ["topic:${MAIN_TOPIC_ID}"],
    "provenance": {"sources": ["actor_statement:smoke"]}
  }
}
JSON
)")"
MAIN_TOPIC_THREAD_ID="$(extract_first_field "$MAIN_TOPIC_RESP" "thread_id")"

CARD_A_TOPIC_RESP="$(post_json "/topics" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "topic": {
    "id": "${CARD_A_TOPIC_ID}",
    "type": "initiative",
    "status": "active",
    "title": "Smoke work item A",
    "summary": "Card A topic",
    "owner_refs": ["actor:${ACTOR_ID}"],
    "board_refs": [],
    "document_refs": [],
    "related_refs": ["topic:${CARD_A_TOPIC_ID}"],
    "provenance": {"sources": ["actor_statement:smoke"]}
  }
}
JSON
)")"
CARD_A_THREAD_ID="$(extract_first_field "$CARD_A_TOPIC_RESP" "thread_id")"

CARD_B_TOPIC_RESP="$(post_json "/topics" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "topic": {
    "id": "${CARD_B_TOPIC_ID}",
    "type": "initiative",
    "status": "active",
    "title": "Smoke work item B",
    "summary": "Card B topic",
    "owner_refs": ["actor:${ACTOR_ID}"],
    "board_refs": [],
    "document_refs": [],
    "related_refs": ["topic:${CARD_B_TOPIC_ID}"],
    "provenance": {"sources": ["actor_statement:smoke"]}
  }
}
JSON
)")"
CARD_B_THREAD_ID="$(extract_first_field "$CARD_B_TOPIC_RESP" "thread_id")"

if [[ -z "$MAIN_TOPIC_THREAD_ID" || -z "$CARD_A_THREAD_ID" || -z "$CARD_B_THREAD_ID" ]]; then
  echo "failed to extract backing thread ids from topic creation responses" >&2
  echo "$MAIN_TOPIC_RESP" >&2
  echo "$CARD_A_TOPIC_RESP" >&2
  echo "$CARD_B_TOPIC_RESP" >&2
  exit 1
fi

echo "creating documents"
post_json "/docs" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "document": {
    "id": "${PRIMARY_DOC_ID}",
    "title": "Smoke Board Primary Doc",
    "status": "active",
    "labels": ["smoke", "board"]
  },
  "refs": ["topic:${MAIN_TOPIC_ID}", "thread:${MAIN_TOPIC_THREAD_ID}"],
  "content": "Primary board document",
  "content_type": "text"
}
JSON
)" >/dev/null

post_json "/docs" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "document": {
    "id": "${CARD_DOC_ID}",
    "title": "Smoke Board Card Doc",
    "status": "active",
    "labels": ["smoke", "board"]
  },
  "refs": ["topic:${CARD_A_TOPIC_ID}", "thread:${CARD_A_THREAD_ID}"],
  "content": "Pinned card document",
  "content_type": "text"
}
JSON
)" >/dev/null

echo "creating board"
BOARD_RESP="$(post_json "/boards" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "board": {
    "id": "${BOARD_ID}",
    "title": "Smoke Board",
    "status": "active",
    "labels": ["smoke", "board"],
    "owners": ["${ACTOR_ID}"],
    "primary_topic_ref": "topic:${MAIN_TOPIC_ID}",
    "thread_id": "${BOARD_ID}",
    "document_refs": ["document:${PRIMARY_DOC_ID}"],
    "card_refs": [],
    "pinned_refs": ["document:${PRIMARY_DOC_ID}"],
    "provenance": {"sources": ["actor_statement:smoke"]}
  }
}
JSON
)")"
BOARD_UPDATED_AT="$(extract_first_field "$BOARD_RESP" "updated_at")"
if [[ -z "$BOARD_UPDATED_AT" ]]; then
  echo "failed to parse board updated_at from response: $BOARD_RESP" >&2
  exit 1
fi

echo "adding cards"
CARD_A_RESP="$(post_json "/boards/${BOARD_ID}/cards" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "if_board_updated_at": "${BOARD_UPDATED_AT}",
  "card_id": "card-smoke-a",
  "thread_id": "${CARD_A_THREAD_ID}",
  "column_key": "backlog",
  "title": "Smoke work item A",
  "body": "Smoke work item A",
  "pinned_document_id": "${CARD_DOC_ID}"
}
JSON
)")"
BOARD_UPDATED_AT="$(extract_first_field "$CARD_A_RESP" "updated_at")"

post_json "/boards/${BOARD_ID}/cards" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "if_board_updated_at": "${BOARD_UPDATED_AT}",
  "card_id": "card-smoke-b",
  "thread_id": "${CARD_B_THREAD_ID}",
  "column_key": "backlog",
  "title": "Smoke work item B",
  "body": "Smoke work item B",
  "after_thread_id": "${CARD_A_THREAD_ID}"
}
JSON
)" >/dev/null

echo "creating packets"
post_json "/packets/receipts" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "artifact": {
    "id": "${RECEIPT_ID}",
    "refs": ["card:card-smoke-a"],
    "summary": "Smoke receipt",
    "provenance": {"sources": ["actor_statement:smoke"]}
  },
  "packet": {
    "receipt_id": "${RECEIPT_ID}",
    "subject_ref": "card:card-smoke-a",
    "outputs": ["document:${PRIMARY_DOC_ID}"],
    "verification_evidence": ["document:${PRIMARY_DOC_ID}"],
    "changes_summary": "Smoke flow completed",
    "known_gaps": []
  }
}
JSON
)" >/dev/null

post_json "/packets/reviews" "$(cat <<JSON
{
  "actor_id": "${ACTOR_ID}",
  "artifact": {
    "id": "${REVIEW_ID}",
    "refs": ["card:card-smoke-a", "artifact:${RECEIPT_ID}"],
    "summary": "Smoke review",
    "provenance": {"sources": ["actor_statement:smoke"]}
  },
  "packet": {
    "review_id": "${REVIEW_ID}",
    "subject_ref": "card:card-smoke-a",
    "receipt_ref": "artifact:${RECEIPT_ID}",
    "outcome": "accept",
    "notes": "Smoke review accepted",
    "evidence_refs": ["artifact:${RECEIPT_ID}"]
  }
}
JSON
)" >/dev/null

TOPICS_JSON="$(get_json "/topics")"
BOARD_WORKSPACE_JSON="$(get_json "/boards/${BOARD_ID}/workspace")"
CARD_LIST_JSON="$(get_json "/cards")"

TOPIC_COUNT="$(extract_first_field "$TOPICS_JSON" "topics" || true)"
CARD_COUNT="$(extract_first_field "$CARD_LIST_JSON" "cards" || true)"
BOARD_CARD_COUNT="$(extract_first_field "$BOARD_WORKSPACE_JSON" "count" || true)"
if [[ -z "$BOARD_CARD_COUNT" ]]; then
  BOARD_CARD_COUNT="$(printf '%s' "$BOARD_WORKSPACE_JSON" | rg -o '"card_count":[0-9]+' | head -n 1 | sed -E 's/.*://')"
fi

echo "smoke summary:"
echo "  main_topic_id: ${MAIN_TOPIC_ID}"
echo "  board_id: ${BOARD_ID}"
echo "  receipt_id: ${RECEIPT_ID}"
echo "  review_id: ${REVIEW_ID}"
echo "  board_card_count: ${BOARD_CARD_COUNT:-0}"
echo "  topics_response_size: ${TOPIC_COUNT:-0}"
echo "  cards_response_size: ${CARD_COUNT:-0}"
