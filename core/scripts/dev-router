#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

CORE_HOST="${CORE_HOST:-127.0.0.1}"
CORE_PORT="${CORE_PORT:-8000}"
BASE_URL="${OAR_ROUTER_BASE_URL:-http://${CORE_HOST}:${CORE_PORT}}"
WORKSPACE_ROOT="${WORKSPACE_ROOT:-$ROOT_DIR/.oar-workspace}"
WORKSPACE_ID="${OAR_ROUTER_WORKSPACE_ID:-ws_main}"
WORKSPACE_NAME="${OAR_ROUTER_WORKSPACE_NAME:-Main}"
STATE_PATH="${OAR_ROUTER_STATE_PATH:-$WORKSPACE_ROOT/router/router-state.json}"
AUTH_STATE_PATH="${OAR_ROUTER_AUTH_STATE_PATH:-$WORKSPACE_ROOT/router/router-auth.json}"
PRINCIPAL_CACHE_TTL="${OAR_ROUTER_PRINCIPAL_CACHE_TTL:-60s}"
RECONNECT_DELAY="${OAR_ROUTER_RECONNECT_DELAY:-3s}"

exec go run ./cmd/oar-router \
  --base-url "$BASE_URL" \
  --workspace-id "$WORKSPACE_ID" \
  --workspace-name "$WORKSPACE_NAME" \
  --state-path "$STATE_PATH" \
  --auth-state-path "$AUTH_STATE_PATH" \
  --principal-cache-ttl "$PRINCIPAL_CACHE_TTL" \
  --reconnect-delay "$RECONNECT_DELAY"
