#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

PORT="${PORT:-18102}"
LISTEN_ADDR="127.0.0.1:${PORT}"
BASE_URL="http://${LISTEN_ADDR}"
WORKSPACE_ID="${WORKSPACE_ID:-ws_smoke_control_plane}"
CONTROL_PLANE_ISSUER="${CONTROL_PLANE_ISSUER:-https://control-plane-smoke.example.test}"
CONTROL_PLANE_AUDIENCE="${CONTROL_PLANE_AUDIENCE:-oar-core}"
SERVICE_ID="${SERVICE_ID:-svc_${WORKSPACE_ID}}"

TMP_DIR="$(mktemp -d)"
WORKSPACE_ROOT="${WORKSPACE_ROOT:-$TMP_DIR/workspace}"
SERVER_LOG="$TMP_DIR/server.log"
HELPER_DIR="$ROOT_DIR/.tmp"
KEY_HELPER="$HELPER_DIR/smoke-control-plane-human-keys.go"
TOKEN_HELPER="$HELPER_DIR/smoke-control-plane-human-token.go"

cleanup() {
  if [[ -n "${SERVER_PID:-}" ]] && kill -0 "$SERVER_PID" 2>/dev/null; then
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
  fi
  rm -f "$KEY_HELPER" "$TOKEN_HELPER"
  rm -rf "$TMP_DIR"
}
trap cleanup EXIT INT TERM

mkdir -p "$HELPER_DIR"

cat >"$KEY_HELPER" <<'EOF'
package main

import (
	"crypto/ed25519"
	"crypto/rand"
	"encoding/base64"
	"fmt"
	"os"
)

func main() {
	controlPlanePublic, controlPlanePrivate, err := ed25519.GenerateKey(rand.Reader)
	if err != nil {
		fmt.Fprintf(os.Stderr, "generate control-plane key: %v\n", err)
		os.Exit(1)
	}
	_, servicePrivate, err := ed25519.GenerateKey(rand.Reader)
	if err != nil {
		fmt.Fprintf(os.Stderr, "generate service key: %v\n", err)
		os.Exit(1)
	}
	fmt.Println(base64.StdEncoding.EncodeToString(controlPlanePublic))
	fmt.Println(base64.StdEncoding.EncodeToString(controlPlanePrivate))
	fmt.Println(base64.StdEncoding.EncodeToString(servicePrivate))
}
EOF

cat >"$TOKEN_HELPER" <<'EOF'
package main

import (
	"fmt"
	"os"
	"time"

	"organization-autorunner-core/internal/controlplaneauth"
)

func main() {
	if len(os.Args) != 9 {
		fmt.Fprintf(os.Stderr, "usage: %s <issuer> <audience> <private_key> <workspace_id> <account_id> <email> <display_name> <launch_id>\n", os.Args[0])
		os.Exit(2)
	}
	privateKey, err := controlplaneauth.ParseEd25519PrivateKeyBase64(os.Args[3])
	if err != nil {
		fmt.Fprintf(os.Stderr, "parse private key: %v\n", err)
		os.Exit(1)
	}
	now := time.Now().UTC()
	signer, err := controlplaneauth.NewWorkspaceHumanGrantSigner(controlplaneauth.WorkspaceHumanGrantSignerConfig{
		Issuer:     os.Args[1],
		Audience:   os.Args[2],
		PrivateKey: privateKey,
		Now:        func() time.Time { return now },
	})
	if err != nil {
		fmt.Fprintf(os.Stderr, "new signer: %v\n", err)
		os.Exit(1)
	}
	token, _, err := signer.Sign(controlplaneauth.WorkspaceHumanGrantInput{
		AccountID:   os.Args[5],
		WorkspaceID: os.Args[4],
		Email:       os.Args[6],
		DisplayName: os.Args[7],
		LaunchID:    os.Args[8],
		TTL:         10 * time.Minute,
	})
	if err != nil {
		fmt.Fprintf(os.Stderr, "sign token: %v\n", err)
		os.Exit(1)
	}
	fmt.Print(token)
}
EOF

KEY_OUTPUT="$(go run "$KEY_HELPER")"
CONTROL_PLANE_PUBLIC_KEY="$(printf '%s\n' "$KEY_OUTPUT" | sed -n '1p')"
CONTROL_PLANE_PRIVATE_KEY="$(printf '%s\n' "$KEY_OUTPUT" | sed -n '2p')"
WORKSPACE_SERVICE_PRIVATE_KEY="$(printf '%s\n' "$KEY_OUTPUT" | sed -n '3p')"

echo "starting oar-core in control-plane human auth mode on ${BASE_URL}"
OAR_HUMAN_AUTH_MODE="control_plane" \
OAR_CONTROL_PLANE_TOKEN_ISSUER="$CONTROL_PLANE_ISSUER" \
OAR_CONTROL_PLANE_TOKEN_AUDIENCE="$CONTROL_PLANE_AUDIENCE" \
OAR_CONTROL_PLANE_WORKSPACE_ID="$WORKSPACE_ID" \
OAR_CONTROL_PLANE_TOKEN_PUBLIC_KEY="$CONTROL_PLANE_PUBLIC_KEY" \
OAR_WORKSPACE_SERVICE_ID="$SERVICE_ID" \
OAR_WORKSPACE_SERVICE_PRIVATE_KEY="$WORKSPACE_SERVICE_PRIVATE_KEY" \
go run ./cmd/oar-core \
  --listen-addr "$LISTEN_ADDR" \
  --workspace-root "$WORKSPACE_ROOT" \
  --schema-path "$ROOT_DIR/../contracts/oar-schema.yaml" \
  >"$SERVER_LOG" 2>&1 &
SERVER_PID=$!

for _ in $(seq 1 80); do
  if curl -fsS "${BASE_URL}/readyz" >/dev/null 2>&1; then
    break
  fi
  sleep 0.1
done

if ! curl -fsS "${BASE_URL}/readyz" >/dev/null 2>&1; then
  echo "server did not become healthy; log follows:" >&2
  cat "$SERVER_LOG" >&2
  exit 1
fi

TOKEN="$(go run "$TOKEN_HELPER" "$CONTROL_PLANE_ISSUER" "$CONTROL_PLANE_AUDIENCE" "$CONTROL_PLANE_PRIVATE_KEY" "$WORKSPACE_ID" "acct_smoke" "smoke@example.com" "Smoke Human" "launch_smoke")"

HANDSHAKE_JSON="$(curl -fsS "${BASE_URL}/meta/handshake")"
if ! printf '%s' "$HANDSHAKE_JSON" | rg -q "\"human_auth_mode\":\"control_plane\""; then
  echo "expected control-plane human_auth_mode in handshake: $HANDSHAKE_JSON" >&2
  exit 1
fi
if ! printf '%s' "$HANDSHAKE_JSON" | rg -q "\"workspace_service_identity_id\":\"${SERVICE_ID}\""; then
  echo "expected workspace_service_identity_id in handshake: $HANDSHAKE_JSON" >&2
  exit 1
fi

THREAD_RESPONSE="$(curl -fsS \
  -H "Authorization: Bearer ${TOKEN}" \
  -H "Content-Type: application/json" \
  -d '{
    "thread": {
      "title": "Control-plane smoke thread",
      "type": "incident",
      "status": "active",
      "priority": "p1",
      "tags": ["smoke", "control-plane"],
      "cadence": "daily",
      "next_check_in_at": "2030-01-01T00:00:00Z",
      "current_summary": "smoke request authenticated by signed control-plane token",
      "next_actions": ["verify"],
      "key_artifacts": [],
      "provenance": {"sources": ["inferred"]}
    }
  }' \
  "${BASE_URL}/threads")"

UPDATED_BY="$(printf '%s' "$THREAD_RESPONSE" \
  | rg -o '"updated_by":"[^"]+"' \
  | head -n 1 \
  | sed -E 's/"updated_by":"([^"]+)"/\1/' || true)"

if [[ -z "$UPDATED_BY" ]]; then
  echo "expected updated_by in thread response: $THREAD_RESPONSE" >&2
  exit 1
fi

echo "control-plane human smoke passed with actor_id=${UPDATED_BY}"
