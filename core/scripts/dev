#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

HOST="${HOST:-127.0.0.1}"
PORT="${PORT:-8000}"
WORKSPACE_ROOT="${WORKSPACE_ROOT:-$ROOT_DIR/.oar-workspace}"
SCHEMA_PATH="${SCHEMA_PATH:-$ROOT_DIR/../contracts/oar-schema.yaml}"

exec go run ./cmd/oar-core \
  --host "$HOST" \
  --port "$PORT" \
  --schema-path "$SCHEMA_PATH" \
  --workspace-root "$WORKSPACE_ROOT"
