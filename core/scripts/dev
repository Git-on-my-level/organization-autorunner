#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

HOST="${HOST:-127.0.0.1}"
PORT="${PORT:-8000}"
WORKSPACE_ROOT="${WORKSPACE_ROOT:-$ROOT_DIR/.oar-workspace}"
SCHEMA_PATH="${SCHEMA_PATH:-$ROOT_DIR/../contracts/oar-schema.yaml}"
OAR_ENABLE_DEV_ACTOR_MODE="${OAR_ENABLE_DEV_ACTOR_MODE:-1}"
OAR_ALLOW_UNAUTHENTICATED_WRITES="${OAR_ALLOW_UNAUTHENTICATED_WRITES:-1}"
export OAR_ENABLE_DEV_ACTOR_MODE
export OAR_ALLOW_UNAUTHENTICATED_WRITES

exec go run ./cmd/oar-core \
  --host "$HOST" \
  --port "$PORT" \
  --schema-path "$SCHEMA_PATH" \
  --workspace-root "$WORKSPACE_ROOT"
