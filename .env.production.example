# ──────────────────────────────────────────────────────────────
# OAR Production Environment
# Copy to .env and fill in values for your deployment.
# ──────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────
# MUST be false in production. Only enable for local dev.
OAR_ALLOW_UNAUTHENTICATED_WRITES=false

# ── WebAuthn / Passkeys ──────────────────────────────────────
# Required for passkey auth. Set to your production domain.
OAR_WEBAUTHN_RPID=oar.example.com
OAR_WEBAUTHN_ORIGIN=https://oar.example.com
OAR_WEBAUTHN_RP_DISPLAY_NAME=OAR

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated origins allowed for cross-origin requests.
# Only needed if web-ui is served from a different origin than core.
# When using the Docker Compose setup (web-ui proxies to core),
# this can typically be left empty.
# OAR_CORS_ALLOWED_ORIGINS=https://oar.example.com

# ── Ports (host-side mapping) ────────────────────────────────
OAR_CORE_PORT=8000
OAR_WEB_UI_PORT=3000

# ── Web-UI Origin ────────────────────────────────────────────
# The public origin of the web-ui (for CSRF protection in SvelteKit).
OAR_WEB_UI_ORIGIN=https://oar.example.com

# ── Graceful Shutdown ────────────────────────────────────────
OAR_SHUTDOWN_TIMEOUT=15s
